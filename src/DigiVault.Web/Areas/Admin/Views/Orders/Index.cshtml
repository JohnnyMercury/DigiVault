@model List<Order>
@using DigiVault.Core.Entities
@{
    ViewData["Title"] = "Orders";
    var searchedTx = ViewBag.SearchedTransaction as DigiVault.Core.Entities.PaymentTransaction;
    var txQuery    = (string?)ViewBag.TxQuery;
}

@* ─────────────────────────────────────────────────────────────────────
   Transaction-search widget — mirrors the Cyborg admin: paste any of
   {transaction-id, provider-id, order-number} and get the matching
   PaymentTransaction back as a preview card + a «Подробнее» modal.
   ───────────────────────────────────────────────────────────────────── *@
<div class="card bg-dark border-secondary mb-4">
    <div class="card-body">
        <h5 class="mb-3" style="color: #ec4899;"><i class="bi bi-search me-2"></i>Поиск транзакций</h5>
        <form method="get" class="d-flex gap-2 mb-2">
            <input type="hidden" name="status" value="@ViewBag.Status"/>
            <input type="hidden" name="search" value="@ViewBag.Search"/>
            <input type="text"
                   name="txQuery"
                   value="@txQuery"
                   class="form-control bg-dark border-secondary text-light"
                   placeholder="Введите номер транзакции, заказа или ID провайдера…"
                   autocomplete="off"/>
            <button type="submit" class="btn btn-pink"><i class="bi bi-search me-1"></i>Найти</button>
            @if (!string.IsNullOrWhiteSpace(txQuery))
            {
                <a class="btn btn-outline-secondary" asp-action="Index"
                   asp-route-status="@ViewBag.Status" asp-route-search="@ViewBag.Search">
                    <i class="bi bi-x-lg me-1"></i>Сбросить
                </a>
            }
        </form>
        <small class="text-muted">Поиск по: номеру транзакции, ID провайдера, номеру заказа</small>

        @if (!string.IsNullOrWhiteSpace(txQuery))
        {
            if (searchedTx == null)
            {
                <div class="alert alert-danger mt-3 mb-0">
                    <i class="bi bi-exclamation-triangle me-1"></i>Транзакция не найдена
                </div>
            }
            else
            {
                var statusBadge = searchedTx.Status switch
                {
                    DigiVault.Core.Enums.PaymentStatus.Completed  => ("bg-success", "Подтвержден"),
                    DigiVault.Core.Enums.PaymentStatus.Pending    => ("bg-warning text-dark", "Ожидание"),
                    DigiVault.Core.Enums.PaymentStatus.Processing => ("bg-info text-dark", "В обработке"),
                    DigiVault.Core.Enums.PaymentStatus.Failed     => ("bg-danger", "Ошибка"),
                    DigiVault.Core.Enums.PaymentStatus.Cancelled  => ("bg-secondary", "Отменён"),
                    DigiVault.Core.Enums.PaymentStatus.Refunded   => ("bg-dark", "Возврат"),
                    DigiVault.Core.Enums.PaymentStatus.Expired    => ("bg-secondary", "Истёк"),
                    _ => ("bg-secondary", searchedTx.Status.ToString()),
                };

                <div class="alert alert-success mt-3 mb-0" style="border-left: 4px solid #22c55e;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-check-circle-fill me-2 text-success fs-4"></i>
                        <strong>Транзакция найдена!</strong>
                    </div>
                    <div class="row g-3 text-light">
                        <div class="col-md-6">
                            <div class="small text-muted">ID транзакции:</div>
                            <div><code style="color: #06b6d4;">@searchedTx.TransactionId</code></div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Пользователь:</div>
                            <div>@(searchedTx.User?.Email ?? $"User #{searchedTx.UserId}")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Сумма:</div>
                            <div><strong>@searchedTx.Amount.ToString("N0") @searchedTx.Currency</strong></div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Создана:</div>
                            <div>@searchedTx.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Статус:</div>
                            <div><span class="badge @statusBadge.Item1">@statusBadge.Item2</span></div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Завершена:</div>
                            <div>@(searchedTx.CompletedAt?.ToString("dd.MM.yyyy HH:mm:ss") ?? "-")</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Провайдер:</div>
                            <div>@searchedTx.ProviderName</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Заказ:</div>
                            <div>
                                @if (searchedTx.Order != null)
                                {
                                    <span class="badge" style="background:#06b6d4;color:#000;">@searchedTx.Order.OrderNumber</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Метод оплаты:</div>
                            <div>@searchedTx.Method.ToString().ToLower()</div>
                        </div>
                        <div class="col-md-6">
                            <div class="small text-muted">Provider ID:</div>
                            <div><code class="small">@(searchedTx.ProviderTransactionId ?? "-")</code></div>
                        </div>
                    </div>
                    <button class="btn btn-info mt-3 tx-search-detail-btn" data-bs-toggle="modal" data-bs-target="#txDetailsModal">
                        <i class="bi bi-info-circle me-1"></i>Подробнее
                    </button>
                </div>
            }
        }
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <form method="get" class="d-flex gap-2">
        <select name="status" class="form-select bg-dark border-secondary" style="width: 150px;">
            <option value="">All Status</option>
            <option value="1" selected="@(ViewBag.Status?.ToString() == "1")">Pending</option>
            <option value="2" selected="@(ViewBag.Status?.ToString() == "2")">Processing</option>
            <option value="3" selected="@(ViewBag.Status?.ToString() == "3")">Completed</option>
            <option value="4" selected="@(ViewBag.Status?.ToString() == "4")">Cancelled</option>
            <option value="5" selected="@(ViewBag.Status?.ToString() == "5")">Refunded</option>
        </select>
        <input type="text" name="search" value="@ViewBag.Search" class="form-control bg-dark border-secondary" placeholder="Order # or email...">
        <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i></button>
    </form>
</div>

<div class="card bg-dark border-secondary">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    var statusClass = order.Status switch
                    {
                        OrderStatus.Completed => "success",
                        OrderStatus.Processing => "info",
                        OrderStatus.Pending => "warning",
                        OrderStatus.Cancelled => "secondary",
                        OrderStatus.Refunded => "danger",
                        _ => "secondary"
                    };
                    <tr>
                        <td><code>@order.OrderNumber</code></td>
                        <td>@order.User?.Email</td>
                        <td class="text-primary fw-bold">@order.TotalAmount.ToString("N0") ₽</td>
                        <td><span class="badge bg-@statusClass">@order.Status</span></td>
                        <td>@order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                        <td>
                            <button type="button"
                                    class="btn btn-sm btn-outline-primary tx-view-btn"
                                    data-order-id="@order.Id"
                                    data-bs-toggle="modal"
                                    data-bs-target="#txDetailsModal">
                                <i class="bi bi-eye"></i> View
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if ((int)ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link bg-dark border-secondary" asp-action="Index" asp-route-page="@i" asp-route-status="@ViewBag.Status" asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}

@* ─────────────────────────────────────────────────────────────────────
   Single modal shell — body content gets injected on demand. Search at
   top of page pre-renders the body when it found a transaction; the
   «View» buttons in the orders table load it via AJAX from
   /Admin/Orders/TransactionPartial/{id}.
   ───────────────────────────────────────────────────────────────────── *@
<div class="modal fade" id="txDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content tx-modal">
            <div class="modal-header tx-modal-header">
                <h5 class="modal-title mb-0"><i class="bi bi-credit-card me-2"></i>Детали транзакции</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body tx-modal-body" id="txDetailsModalBody">
                @if (searchedTx != null)
                {
                    @await Html.PartialAsync("_TransactionDetailsModalBody", searchedTx)
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <div class="spinner-border text-info" role="status"></div>
                        <div class="mt-2">Загрузка…</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const modalBody = document.getElementById('txDetailsModalBody');
        const initialBody = modalBody.innerHTML;

        // «View» buttons in the orders table fetch the transaction partial
        // on demand and inject it into the shared modal body. Reset to the
        // loading spinner on every open so stale data from a previous order
        // never leaks into a fresh click.
        document.querySelectorAll('.tx-view-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                const orderId = this.getAttribute('data-order-id');
                modalBody.innerHTML =
                    '<div class="text-center text-muted py-5">' +
                    '  <div class="spinner-border text-info" role="status"></div>' +
                    '  <div class="mt-2">Загрузка…</div>' +
                    '</div>';
                fetch('/Admin/Orders/TransactionPartial/' + orderId)
                    .then(r => r.text())
                    .then(html => { modalBody.innerHTML = html; })
                    .catch(() => {
                        modalBody.innerHTML =
                            '<div class="alert alert-danger m-3">Не удалось загрузить детали.</div>';
                    });
            });
        });

        // «Подробнее» on the search result restores the pre-rendered body
        // (avoids an extra roundtrip for data the server already shipped).
        document.querySelectorAll('.tx-search-detail-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                modalBody.innerHTML = initialBody;
            });
        });
    })();
</script>

<style>
    /* Pink search button matches the Cyborg accent. */
    .btn-pink { background: #ec4899; color: #fff; border: none; }
    .btn-pink:hover { background: #db2777; color: #fff; }

    /* Modal frame — dark to match the rest of /Admin/* surfaces. The pink
       header is preserved from the Cyborg reference so support sees the
       same visual anchor between the two sites. */
    .tx-modal {
        background: #111827;
        color: #e5e7eb;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        overflow: hidden;
    }
    .tx-modal-header {
        background: linear-gradient(135deg, #ec4899 0%, #be185d 100%);
        color: #fff;
        border-bottom: none;
        padding: 1rem 1.5rem;
    }
    .tx-modal-body {
        background: #0f1623;
        color: #e5e7eb;
        padding: 1.75rem;
    }
    .tx-section-title {
        color: #ec4899;
        font-weight: 700;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(236, 72, 153, 0.2);
    }
    .tx-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.65rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    .tx-row:last-child { border-bottom: none; }
    .tx-label {
        min-width: 140px;
        color: #94a3b8;
        margin: 0;
        font-size: 0.88rem;
        font-weight: 500;
    }
    /* Inputs look like plain inline text by default — no border, no
       background, just typography. Per support request: «всё должно
       быть одного цвета, не надо всяких прямоугольников». Editing
       capability is hinted only when the user actually clicks/focuses
       a value (subtle pink underline + faint bg). */
    .tx-input {
        flex: 1;
        min-width: 0;
        background: transparent;
        border: 1px solid transparent;
        padding: 0.4rem 0.5rem;
        font-size: 0.95rem;
        color: #e5e7eb;
        border-radius: 6px;
        transition: border-color 0.15s, background-color 0.15s;
        font-family: inherit;
    }
    .tx-input:hover {
        background: rgba(255, 255, 255, 0.03);
    }
    .tx-input:focus {
        border-color: rgba(236, 72, 153, 0.5);
        background: rgba(255, 255, 255, 0.05);
        outline: none;
    }
    .tx-input-link { color: #06b6d4; font-family: monospace; font-size: 0.88rem; }
    .tx-input-bold { font-weight: 700; font-size: 1.05rem; }
    .tx-input-muted { color: #94a3b8; }
    /* Status pill is always green by request — it's a brand element,
       not a state indicator. The actual status string still varies
       (Successfully / Pending / Failed / …) so the operator can read it. */
    .tx-input-status {
        background: #22c55e !important;
        color: #fff !important;
        font-weight: 600;
        max-width: 200px;
        text-align: center;
        border-color: transparent !important;
    }
    .tx-input-status:hover, .tx-input-status:focus {
        background: #22c55e !important;
        border-color: transparent !important;
    }
    .tx-input-badge {
        background: #06b6d4 !important;
        color: #0a0a0f !important;
        font-weight: 600;
        max-width: 320px;
        padding: 0.4rem 0.9rem;
        border-radius: 16px;
        border-color: transparent !important;
    }
    .tx-input-badge:hover, .tx-input-badge:focus {
        background: #06b6d4 !important;
        border-color: transparent !important;
    }

    @@media (max-width: 768px) {
        .tx-row { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
        .tx-label { min-width: 0; }
        .tx-input, .tx-input-badge, .tx-input-status { max-width: 100% !important; width: 100%; }
    }
</style>
