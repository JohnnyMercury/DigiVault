@model DigiVault.Core.Entities.PaymentProviderConfig
@{
    ViewData["Title"] = $"Редактировать: {Model.DisplayName}";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-light btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Назад
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="data-card">
            <div class="data-card-header">
                <h5 class="data-card-title">
                    <i class="bi bi-pencil me-2"></i>@Model.DisplayName
                </h5>
                <code style="color: #4facfe;">@Model.Name</code>
            </div>
            <div class="p-3">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Name" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Отображаемое имя</label>
                            <input asp-for="DisplayName" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Приоритет</label>
                            <input asp-for="Priority" type="number" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Комиссия %</label>
                            <input asp-for="Commission" type="number" step="0.1" class="form-control" />
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-6">
                            <label class="form-label">API Key</label>
                            <input asp-for="ApiKey" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Secret Key</label>
                            <input asp-for="SecretKey" class="form-control" type="password" />
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-md-4">
                            <label class="form-label">Merchant ID</label>
                            <input asp-for="MerchantId" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Мин. сумма</label>
                            <input asp-for="MinAmount" type="number" step="1" class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Макс. сумма</label>
                            <input asp-for="MaxAmount" type="number" step="1" class="form-control" />
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <label class="form-label">Дополнительные настройки (JSON)</label>
                            <textarea asp-for="Settings" class="form-control" rows="3" style="font-family: monospace;"></textarea>
                        </div>
                    </div>

                    @{
                        var enabledMethodsList = (Model.EnabledMethods ?? "card,sbp,qr,p2p")
                            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                            .Select(m => m.ToLowerInvariant())
                            .ToHashSet();
                    }

                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <label class="form-label d-flex align-items-center gap-2">
                                Доступно для методов оплаты
                                <span class="badge" style="background: rgba(102,126,234,0.18); color: #a5b4fc; font-weight: 500;">Видимость</span>
                            </label>
                            <div class="text-muted small mb-2">
                                В пикере на шаге 2 провайдер будет показан только для отмеченных методов.
                                Если ни один не отмечен — провайдер недоступен в публичном пикере.
                            </div>
                            <div class="d-flex flex-wrap gap-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="EnabledMethodsList" value="card"
                                           id="method_card" @(enabledMethodsList.Contains("card") ? "checked" : "") />
                                    <label class="form-check-label" for="method_card">
                                        <i class="bi bi-credit-card me-1"></i>Карта
                                    </label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="EnabledMethodsList" value="sbp"
                                           id="method_sbp" @(enabledMethodsList.Contains("sbp") ? "checked" : "") />
                                    <label class="form-check-label" for="method_sbp">
                                        <i class="bi bi-lightning-charge me-1"></i>СБП
                                    </label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="EnabledMethodsList" value="qr"
                                           id="method_qr" @(enabledMethodsList.Contains("qr") ? "checked" : "") />
                                    <label class="form-check-label" for="method_qr">
                                        <i class="bi bi-qr-code me-1"></i>QR-код
                                    </label>
                                </div>
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="EnabledMethodsList" value="p2p"
                                           id="method_p2p" @(enabledMethodsList.Contains("p2p") ? "checked" : "") />
                                    <label class="form-check-label" for="method_p2p">
                                        <i class="bi bi-people me-1"></i>P2P
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3 mt-1">
                        <div class="col-auto">
                            <div class="form-check form-switch">
                                <input asp-for="IsEnabled" class="form-check-input" />
                                <label class="form-check-label" asp-for="IsEnabled">Активен</label>
                            </div>
                            <div class="text-muted small">Провайдер обрабатывает платежи</div>
                        </div>
                        <div class="col-auto">
                            <div class="form-check form-switch">
                                <input asp-for="IsVisible" class="form-check-input" />
                                <label class="form-check-label" asp-for="IsVisible">Виден пользователям</label>
                            </div>
                            <div class="text-muted small">Если выкл — скрыт из публичного пикера<br/>(админы всё ещё видят)</div>
                        </div>
                        <div class="col-auto">
                            <div class="form-check form-switch">
                                <input asp-for="IsTestMode" class="form-check-input" />
                                <label class="form-check-label" asp-for="IsTestMode">Тестовый режим</label>
                            </div>
                            <div class="text-muted small">Sandbox / песочница</div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>Сохранить
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
