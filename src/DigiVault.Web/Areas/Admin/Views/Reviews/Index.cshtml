@using DigiVault.Core.Entities
@model List<ProductReview>
@{
    ViewData["Title"] = "Отзывы";
    var search = (string?)ViewBag.Search;
    var category = (string?)ViewBag.Category;
    var rating = (int?)ViewBag.Rating;
    var hidden = (bool?)ViewBag.Hidden;
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var total = (int)ViewBag.Total;
    var totalAll = (int)ViewBag.TotalAll;
    var totalApproved = (int)ViewBag.TotalApproved;
    var totalHidden = (int)ViewBag.TotalHidden;
    var avgRating = (double)ViewBag.AvgRating;

    string ProductNameOf(ProductReview r)
    {
        if (r.Game != null) return $"[Игра] {r.Game.Name}";
        if (r.GiftCard != null) return $"[GC] {r.GiftCard.Name}";
        if (r.VpnProvider != null) return $"[VPN] {r.VpnProvider.Name}";
        return "—";
    }
}

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="stat-icon users"><i class="bi bi-chat-square-text"></i></div>
            <div class="stat-value">@totalAll</div>
            <div class="stat-label">Всего отзывов</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="stat-icon revenue"><i class="bi bi-check2-circle"></i></div>
            <div class="stat-value">@totalApproved</div>
            <div class="stat-label">Опубликовано</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="stat-icon orders"><i class="bi bi-eye-slash"></i></div>
            <div class="stat-value">@totalHidden</div>
            <div class="stat-label">Скрыто</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="stat-icon products"><i class="bi bi-star-fill"></i></div>
            <div class="stat-value">@avgRating.ToString("F2")</div>
            <div class="stat-label">Средний рейтинг</div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="data-card mb-4">
    <div class="p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small text-muted">Поиск</label>
                <input type="text" name="search" value="@search" class="form-control" placeholder="Автор, текст, заголовок...">
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">Категория</label>
                <select name="category" class="form-select">
                    <option value="" selected="@(string.IsNullOrEmpty(category))">Все</option>
                    <option value="games" selected="@(category == "games")">Игровая валюта</option>
                    <option value="telegram" selected="@(category == "telegram")">Telegram</option>
                    <option value="giftcards" selected="@(category == "giftcards")">Подарочные карты</option>
                    <option value="vpn" selected="@(category == "vpn")">VPN</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">Рейтинг</label>
                <select name="rating" class="form-select">
                    <option value="" selected="@(!rating.HasValue)">Любой</option>
                    @for (int r = 5; r >= 1; r--)
                    {
                        <option value="@r" selected="@(rating == r)">@r ★</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small text-muted">Статус</label>
                <select name="hidden" class="form-select">
                    <option value="" selected="@(!hidden.HasValue)">Все</option>
                    <option value="false" selected="@(hidden == false)">Только опубликованные</option>
                    <option value="true" selected="@(hidden == true)">Только скрытые</option>
                </select>
            </div>
            <div class="col-md-3 text-end">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search me-1"></i>Применить</button>
                <a href="@Url.Action("Index")" class="btn btn-outline-light">Сбросить</a>
            </div>
        </form>
    </div>
</div>

<!-- List -->
<div class="data-card">
    <div class="data-card-header">
        <h5 class="data-card-title">Найдено: @total</h5>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">Ничего не найдено</div>
    }
    else
    {
        foreach (var r in Model)
        {
            <div class="p-4 admin-review @(r.IsApproved ? "" : "hidden-review")" style="border-bottom:1px solid var(--card-border);">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-2">
                    <div>
                        <strong style="color:#fff;">@r.AuthorName</strong>
                        @if (!string.IsNullOrEmpty(r.AuthorRole))
                        {
                            <span class="text-muted small ms-2">@r.AuthorRole</span>
                        }
                        @if (r.UserId != null)
                        {
                            <span class="badge bg-info ms-2">Реальный юзер</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ms-2">Демо</span>
                        }
                        @if (!r.IsApproved)
                        {
                            <span class="badge bg-danger ms-2">Скрыт</span>
                        }
                    </div>
                    <div class="text-muted small">@r.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <div class="mb-2">
                    @for (int s = 1; s <= 5; s++)
                    {
                        <i class="bi @(s <= r.Rating ? "bi-star-fill" : "bi-star")" style="color:@(s <= r.Rating ? "#fbbf24" : "rgba(255,255,255,0.15)");"></i>
                    }
                    <span class="ms-2 text-muted small">— @ProductNameOf(r)</span>
                    <span class="text-muted small ms-2">Полезно: @r.HelpfulCount</span>
                </div>
                <div class="mb-2" style="color:#fff; font-weight:600;">@r.Title</div>
                <div class="mb-3 text-muted">@r.Text</div>

                @if (!string.IsNullOrEmpty(r.AdminReply))
                {
                    <div class="admin-reply-existing mb-3">
                        <div class="small text-muted mb-1">
                            <i class="bi bi-reply-fill me-1"></i>Ответ команды
                            @if (r.AdminReplyAt.HasValue)
                            {
                                <span class="ms-2">@r.AdminReplyAt.Value.ToString("dd.MM.yyyy")</span>
                            }
                        </div>
                        <div style="color:rgba(255,255,255,0.75);">@r.AdminReply</div>
                    </div>
                }

                <div class="d-flex gap-2 flex-wrap">
                    <form asp-action="Toggle" asp-route-id="@r.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm @(r.IsApproved ? "btn-outline-warning" : "btn-outline-success")">
                            <i class="bi @(r.IsApproved ? "bi-eye-slash" : "bi-eye")"></i>
                            @(r.IsApproved ? "Скрыть" : "Опубликовать")
                        </button>
                    </form>
                    <button type="button" class="btn btn-sm btn-outline-light" onclick="toggleReply(@r.Id)">
                        <i class="bi bi-reply"></i> @(string.IsNullOrEmpty(r.AdminReply) ? "Ответить" : "Изменить ответ")
                    </button>
                    <form asp-action="Delete" asp-route-id="@r.Id" method="post" class="d-inline" onsubmit="return confirm('Удалить отзыв?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i> Удалить
                        </button>
                    </form>
                </div>

                <form asp-action="Reply" asp-route-id="@r.Id" method="post" class="mt-3 reply-form" id="reply-@r.Id" style="display:none;">
                    @Html.AntiForgeryToken()
                    <textarea name="reply" rows="3" maxlength="2000" class="form-control mb-2" placeholder="Ответ от имени Команды Key Zona...">@r.AdminReply</textarea>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-check-lg me-1"></i>Сохранить ответ
                    </button>
                    <small class="text-muted ms-2">Оставьте пустым чтобы удалить ответ</small>
                </form>
            </div>
        }
    }

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="p-3 d-flex justify-content-center">
            <nav>
                <ul class="pagination">
                    @if (page > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="?search=@search&category=@category&rating=@rating&hidden=@hidden&page=@(page - 1)">&laquo;</a>
                        </li>
                    }
                    @{
                        int fromP = Math.Max(1, page - 2);
                        int toP = Math.Min(totalPages, page + 2);
                    }
                    @for (int p = fromP; p <= toP; p++)
                    {
                        <li class="page-item @(p == page ? "active" : "")">
                            <a class="page-link" href="?search=@search&category=@category&rating=@rating&hidden=@hidden&page=@p">@p</a>
                        </li>
                    }
                    @if (page < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="?search=@search&category=@category&rating=@rating&hidden=@hidden&page=@(page + 1)">&raquo;</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

@section Styles {
<style>
    .admin-review.hidden-review { opacity: 0.5; }
    .admin-reply-existing { background: rgba(102,126,234,0.08); border-left: 3px solid #667eea; padding: 0.75rem 1rem; border-radius: 8px; }
    .pagination .page-link { background: var(--card-bg); border-color: var(--card-border); color: rgba(255,255,255,0.6); }
    .pagination .page-link:hover { background: var(--card-hover); color: #fff; }
    .pagination .page-item.active .page-link { background: var(--primary-gradient); border-color: transparent; }
</style>
}
@section Scripts {
<script>
    function toggleReply(id) {
        const f = document.getElementById('reply-' + id);
        f.style.display = f.style.display === 'none' ? 'block' : 'none';
    }
</script>
}
