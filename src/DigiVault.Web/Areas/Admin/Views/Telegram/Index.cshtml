@using DigiVault.Core.Entities
@{
    ViewData["Title"] = "Telegram";
    var starsCard = ViewBag.StarsCard as GiftCard;
    var premiumCard = ViewBag.PremiumCard as GiftCard;
    var premiumProducts = premiumCard?.Products?.OrderBy(p => p.SortOrder).ThenBy(p => p.Price).ToList()
        ?? new List<GameProduct>();
    var starRate = (string)ViewBag.StarRate;
    var minStars = (string)ViewBag.MinStars;
    var maxStars = (string)ViewBag.MaxStars;
    var telegramOrders = (int)ViewBag.TelegramOrders;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0"><i class="bi bi-send-fill me-2" style="color: #2AABEE;"></i>Telegram</h4>
        <small class="text-muted">Управление звёздами и Premium подписками</small>
    </div>
    <a href="/Catalog/Telegram" target="_blank" class="btn btn-outline-light">
        <i class="bi bi-box-arrow-up-right me-1"></i>Открыть на сайте
    </a>
</div>

<!-- Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, rgba(42, 171, 238, 0.2), rgba(34, 158, 217, 0.2)); color: #2AABEE;">
                <i class="bi bi-star-fill"></i>
            </div>
            <div class="stat-value">@starRate &#8381;</div>
            <div class="stat-label">Цена за 1 звезду</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.2), rgba(118, 75, 162, 0.2)); color: #667eea;">
                <i class="bi bi-diamond-fill"></i>
            </div>
            <div class="stat-value">@premiumProducts.Count(p => p.IsActive)</div>
            <div class="stat-label">Тарифов Premium</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon products">
                <i class="bi bi-hash"></i>
            </div>
            <div class="stat-value">@minStars - @maxStars</div>
            <div class="stat-label">Диапазон звёзд</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-icon orders">
                <i class="bi bi-bag-check-fill"></i>
            </div>
            <div class="stat-value">@telegramOrders</div>
            <div class="stat-label">Заказов Telegram</div>
        </div>
    </div>
</div>

<!-- Stars Card Image -->
<div class="data-card mb-4">
    <div class="data-card-header">
        <h5 class="data-card-title"><i class="bi bi-image me-2" style="color: #2AABEE;"></i>Карточка «Звёзды Телеграма» в каталоге</h5>
    </div>
    <div class="p-4">
        <form asp-action="UpdateStarsImage" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row align-items-center g-3">
                <div class="col-auto">
                    @if (!string.IsNullOrEmpty(starsCard?.ImageUrl))
                    {
                        <img src="@starsCard.ImageUrl" alt="Stars" style="width: 120px; height: 120px; object-fit: cover; border-radius: 12px; border: 1px solid var(--card-border);">
                    }
                    else
                    {
                        <div style="width: 120px; height: 120px; border-radius: 12px; background: linear-gradient(135deg, #2AABEE, #229ED9); display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-star-fill" style="font-size: 2.5rem; color: #FFD700;"></i>
                        </div>
                    }
                </div>
                <div class="col">
                    <label class="form-label" style="color: rgba(255,255,255,0.6); font-size: 0.85rem;">Изображение карточки</label>
                    <input type="file" name="imageFile" class="form-control" accept="image/*">
                    <small class="text-muted">Рекомендуемый размер: 400×400 px. Отображается в каталоге.</small>
                    <div class="mt-2">
                        <button type="submit" class="btn btn-primary btn-sm">
                            <i class="bi bi-upload me-1"></i>Загрузить
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Star Settings -->
<div class="data-card mb-4">
    <div class="data-card-header">
        <h5 class="data-card-title"><i class="bi bi-star-fill me-2" style="color: #FFD700;"></i>Настройки звёзд</h5>
    </div>
    <div class="p-4">
        <form asp-action="UpdateStarSettings" method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" style="color: rgba(255,255,255,0.6); font-size: 0.85rem;">Курс (&#8381; за 1 звезду)</label>
                    <div class="input-group">
                        <input type="text" name="starRate" class="form-control" value="@starRate" required>
                        <span class="input-group-text" style="background: rgba(255,255,255,0.05); border-color: var(--card-border); color: rgba(255,255,255,0.5);">&#8381;</span>
                    </div>
                    <small class="text-muted">Например: 1.5 означает 75&#8381; за 50 звёзд</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label" style="color: rgba(255,255,255,0.6); font-size: 0.85rem;">Минимум звёзд</label>
                    <input type="number" name="minStars" class="form-control" value="@minStars" min="1" required>
                    <small class="text-muted">Минимальный заказ</small>
                </div>
                <div class="col-md-4">
                    <label class="form-label" style="color: rgba(255,255,255,0.6); font-size: 0.85rem;">Максимум звёзд</label>
                    <input type="number" name="maxStars" class="form-control" value="@maxStars" min="1" required>
                    <small class="text-muted">Максимальный заказ</small>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Сохранить настройки
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Premium Plans -->
<div class="data-card mb-4">
    <div class="data-card-header">
        <h5 class="data-card-title"><i class="bi bi-diamond-fill me-2" style="color: #667eea;"></i>Тарифы Telegram Premium</h5>
        <a asp-action="CreateProduct" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Добавить тариф
        </a>
    </div>

    @if (premiumProducts.Any())
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Период</th>
                        <th>Цена</th>
                        <th>Старая цена</th>
                        <th>Скидка</th>
                        <th>Сток</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in premiumProducts)
                    {
                        <tr style="@(product.IsActive ? "" : "opacity: 0.5;")">
                            <td style="font-weight: 600;">@product.Name</td>
                            <td>@product.Amount</td>
                            <td style="font-weight: 600; color: #22c55e;">@product.Price.ToString("N0") &#8381;</td>
                            <td>
                                @if (product.OldPrice.HasValue && product.OldPrice > 0)
                                {
                                    <span style="text-decoration: line-through; color: rgba(255,255,255,0.4);">@product.OldPrice.Value.ToString("N0") &#8381;</span>
                                }
                            </td>
                            <td>
                                @if (product.Discount > 0)
                                {
                                    <span class="badge" style="background: rgba(34, 197, 94, 0.15); color: #22c55e;">-@product.Discount%</span>
                                }
                            </td>
                            <td>@product.StockQuantity</td>
                            <td>
                                @if (product.IsActive)
                                {
                                    <span class="badge-status completed">Активен</span>
                                }
                                else
                                {
                                    <span class="badge-status cancelled">Скрыт</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="EditProduct" asp-route-id="@product.Id" class="btn btn-outline-light btn-sm">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleProduct" asp-route-id="@product.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-light btn-sm" title="@(product.IsActive ? "Скрыть" : "Показать")">
                                            <i class="bi @(product.IsActive ? "bi-eye-slash" : "bi-eye")"></i>
                                        </button>
                                    </form>
                                    <form asp-action="DeleteProduct" asp-route-id="@product.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Удалить тариф?')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-diamond fs-1 mb-3 d-block"></i>
            <h5>Тарифы не найдены</h5>
            <p class="text-muted">Добавьте тарифы Telegram Premium</p>
        </div>
    }
</div>

