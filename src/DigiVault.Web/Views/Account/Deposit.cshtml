@model DepositViewModel
@{
    ViewData["Title"] = "Пополнение баланса";
    var isAdmin = User.IsInRole("Admin");
}

<style>
    .deposit-page {
        max-width: 520px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .deposit-card {
        background: linear-gradient(145deg, #1f1f3a 0%, #161630 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .deposit-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .deposit-balance {
        background: rgba(102, 126, 234, 0.1);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 14px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .deposit-balance i { font-size: 1.25rem; color: #667eea; }
    .deposit-balance-text { font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); }
    .deposit-balance-value { font-weight: 700; color: white; font-size: 1.15rem; }

    .deposit-admin-badge {
        background: rgba(34, 197, 94, 0.1);
        border: 1px solid rgba(34, 197, 94, 0.25);
        border-radius: 12px;
        padding: 0.85rem 1.25rem;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }
    .deposit-admin-badge i { color: #22c55e; font-size: 1rem; }

    .deposit-label {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.6rem;
        color: rgba(255, 255, 255, 0.8);
    }

    .deposit-input-wrap {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        margin-bottom: 0.5rem;
        gap: 0.5rem;
        transition: border-color 0.2s ease;
    }
    .deposit-input-wrap:focus-within {
        border-color: rgba(102, 126, 234, 0.5);
    }

    .deposit-input-wrap .currency { color: rgba(255, 255, 255, 0.4); font-size: 1.15rem; font-weight: 600; }

    .deposit-input-wrap input {
        flex-grow: 1;
        background: transparent;
        border: none;
        color: white;
        font-size: 1.15rem;
        font-weight: 600;
    }
    .deposit-input-wrap input:focus { outline: none; }
    .deposit-input-wrap input::placeholder { color: rgba(255, 255, 255, 0.25); }

    .quick-amounts {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1.75rem;
        margin-top: 0.75rem;
    }

    .quick-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 0.55rem 1.1rem;
        color: white;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .quick-btn:hover {
        border-color: rgba(102, 126, 234, 0.4);
        background: rgba(102, 126, 234, 0.1);
    }

    .deposit-submit {
        width: 100%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 12px;
        padding: 0.95rem;
        color: white;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    .deposit-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
    }
    .deposit-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .deposit-back {
        display: block;
        text-align: center;
        margin-top: 1.25rem;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.85rem;
        text-decoration: none;
        transition: color 0.2s ease;
    }
    .deposit-back:hover { color: rgba(255, 255, 255, 0.8); }

    /* Payment methods */
    .deposit-pay-methods {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .deposit-pay-method {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .deposit-pay-method:hover:not(.disabled) {
        border-color: rgba(102, 126, 234, 0.3);
        background: rgba(102, 126, 234, 0.05);
    }
    .deposit-pay-method.selected {
        border-color: #667eea;
        background: rgba(102, 126, 234, 0.08);
    }
    .deposit-pay-method.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .deposit-pay-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .deposit-pay-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: white;
    }

    .deposit-pay-name {
        font-weight: 600;
        font-size: 0.9rem;
        color: white;
    }
    .deposit-pay-desc {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.45);
        margin-top: 1px;
    }

    .deposit-pay-badge {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
    }
    .deposit-pay-badge.soon {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.4);
    }
    .deposit-pay-badge.active {
        background: rgba(34, 197, 94, 0.15);
        color: #22c55e;
    }

    .deposit-pay-radio {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid rgba(255, 255, 255, 0.2);
        transition: all 0.2s ease;
        flex-shrink: 0;
    }
    .deposit-pay-radio.active {
        border-color: #667eea;
        background: radial-gradient(circle, #667eea 40%, transparent 45%);
    }

    .deposit-pay-right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
</style>

<div class="deposit-page">
    <div class="deposit-card">
        <div class="deposit-title">
            <i class="bi bi-plus-circle"></i>
            Пополнение баланса
        </div>

        <div class="deposit-balance">
            <i class="bi bi-wallet2"></i>
            <div>
                <div class="deposit-balance-text">Текущий баланс</div>
                <div class="deposit-balance-value">@Model.CurrentBalance.ToString("N0") ₽</div>
            </div>
        </div>

        @if (TempData["Error"] is string err && !string.IsNullOrEmpty(err))
        {
            <div style="background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.3); color: #fca5a5; border-radius: 12px; padding: 0.85rem 1rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.55rem; font-size: 0.85rem;">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@err</span>
            </div>
        }
        @if (TempData["Success"] is string ok && !string.IsNullOrEmpty(ok))
        {
            <div style="background: rgba(34, 197, 94, 0.1); border: 1px solid rgba(34, 197, 94, 0.3); color: #86efac; border-radius: 12px; padding: 0.85rem 1rem; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.55rem; font-size: 0.85rem;">
                <i class="bi bi-check-circle-fill"></i>
                <span>@ok</span>
            </div>
        }

        @if (isAdmin)
        {
            <div class="deposit-admin-badge">
                <i class="bi bi-shield-check"></i>
                <span>Админ-режим: начисление средств без оплаты</span>
            </div>
        }

        @* The form ALSO carries id="paymentStep1" so _PaymentMethodPicker
           can hide/show it when toggling step-2. Without that id the picker
           silently refuses to open (its guard requires both step1 and step2). *@
        <form asp-action="Deposit" method="post" id="depositForm" data-step="paymentStep1">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="deposit-label">Сумма пополнения</div>
            <div class="deposit-input-wrap">
                <span class="currency">₽</span>
                <input asp-for="Amount" placeholder="0" type="number" min="1" step="1" required />
            </div>
            <span asp-validation-for="Amount" class="text-danger small d-block"></span>

            <div class="quick-amounts">
                <button type="button" class="quick-btn" data-amount="100">100 ₽</button>
                <button type="button" class="quick-btn" data-amount="500">500 ₽</button>
                <button type="button" class="quick-btn" data-amount="1000">1 000 ₽</button>
                <button type="button" class="quick-btn" data-amount="5000">5 000 ₽</button>
                <button type="button" class="quick-btn" data-amount="10000">10 000 ₽</button>
            </div>

            <div class="deposit-label">Способ оплаты</div>

            @* Optional admin-only «manual top-up» tile rendered above the
               unified picker. Same look-and-feel via .pmtile classes. *@
            @if (isAdmin)
            {
                <div class="pmtiles" style="margin-bottom: 0.5rem;">
                    <div class="pmtile selected" data-method="admin" data-available="true" onclick="selectPayMethod(this)">
                        <div class="pmtile-left">
                            <span class="pmtile-icon" style="background: linear-gradient(135deg, #22c55e, #16a34a);"><i class="bi bi-shield-check"></i></span>
                            <div>
                                <div class="pmtile-title">Админ-начисление</div>
                                <div class="pmtile-desc">Мгновенное зачисление без оплаты</div>
                            </div>
                        </div>
                        <div class="pmtile-right">
                            <span class="pmtile-badge instant">Доступно</span>
                            <span class="pmtile-radio active"></span>
                        </div>
                    </div>
                </div>
            }

            @{
                var __depTiles = new DigiVault.Web.Models.Payment.PaymentTilesViewModel
                {
                    ShowBalance     = false,
                    SelectedCode    = isAdmin ? "admin" : "card",
                    OnSelectJs      = "selectPayMethod",
                    HiddenInputName = "PaymentMethod",
                    HiddenInputId   = "paymentMethod"
                };
            }
            <partial name="_PaymentMethodTiles" model="__depTiles" />

            @* Hidden field carries the chosen PSP code (enot / paymentlink)
               from the step-2 picker. Empty for admin-credit flow. *@
            <input type="hidden" name="Provider" id="depositProvider" value="" />

            <button type="button" class="deposit-submit" id="depositBtn" style="margin-top: 1.25rem;">
                <i class="bi bi-check-circle"></i>
                <span id="depositBtnText">@(isAdmin ? "Начислить" : "Перейти к оплате")</span>
            </button>
        </form>

        @* Step-2 PSP picker - same partial as on catalog modals. Hidden by
           default; the «Перейти к оплате» button opens it for non-admin
           methods, then submits the form once the user picks a PSP. *@
        <div id="paymentStep2Wrapper" style="display:none; margin-top: 1.25rem;">
            @await Html.PartialAsync("_PaymentMethodPicker")
        </div>

        <a href="/Account/Dashboard" class="deposit-back">
            <i class="bi bi-arrow-left me-1"></i> Вернуться в личный кабинет
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.quick-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.getElementById('Amount').value = this.dataset.amount;
            });
        });

        // The unified _PaymentMethodTiles partial defines window.selectPayMethod
        // which manages selected-state and updates the hidden input flagged
        // with [data-pmtiles-target]. We just need to clear the optional
        // admin-tile selection (which lives outside the partial's container)
        // when the user picks one of the regular methods, and the inverse.
        window.onPayMethodChange = function (code, tile) {
            // Find the standalone admin tile (it's in its own .pmtiles wrapper).
            var adminTile = document.querySelector('.pmtile[data-method="admin"]');
            if (!adminTile) return;
            if (code === 'admin') {
                // partial cleared its own selection - also pull all .pmtile.selected
                // outside the partial's container so only admin stays selected.
                var partialContainer = tile.closest('.pmtiles');
                document.querySelectorAll('.pmtile.selected').forEach(function (t) {
                    if (t !== tile && t.closest('.pmtiles') !== partialContainer) {
                        // already cleared by partial; nothing to do
                    }
                });
            } else {
                // Method picked from the partial - drop admin's selected state.
                adminTile.classList.remove('selected');
                var r = adminTile.querySelector('.pmtile-radio');
                if (r) r.classList.remove('active');
            }
        };

        // When the user clicks a disabled (Скоро) tile.
        window.onPayMethodUnavailable = function (code) {
            // Could surface inline notice; for now we just no-op - server-side
            // rejects qr/p2p with a friendly TempData banner if it ever submits.
            console.info('Метод', code, 'пока не подключён');
        };

        // ── Step-2 picker glue ─────────────────────────────────────────────
        // Same flow as catalog modals: the «Перейти к оплате» button doesn't
        // submit the form directly. For admin-credit / balance-style methods
        // we POST as-is. For Card / СБП / QR we open the PSP picker first;
        // when the user confirms a PSP, the picker calls
        // window.submitPurchaseWithService(method, providerCode, _) which we
        // wire to set the hidden Provider field and submit the form.
        var depositForm = document.getElementById('depositForm');
        var depositBtn  = document.getElementById('depositBtn');

        depositBtn.addEventListener('click', function () {
            var method = (document.getElementById('paymentMethod').value || '').toLowerCase();
            if (method === 'admin') {
                // Manual admin credit - go straight to POST.
                depositForm.submit();
                return;
            }
            if (!method) {
                alert('Выберите способ оплаты');
                return;
            }
            // Real payment - open step-2 picker. lastSelectedPrice drives
            // the Pay-button label inside the picker.
            var amt = parseFloat(document.getElementById('Amount').value || '0');
            if (!amt || amt <= 0) {
                alert('Введите сумму пополнения');
                document.getElementById('Amount').focus();
                return;
            }
            window.lastSelectedPrice = amt;
            if (typeof window.openPaymentStep2 === 'function') {
                window.openPaymentStep2(method);
            } else {
                console.error('Step-2 picker not loaded - submitting without provider');
                depositForm.submit();
            }
        });

        // Picker calls this after the user clicks «Оплатить» on step 2.
        // We stash the chosen PSP code into the form and submit.
        window.submitPurchaseWithService = function (method, providerCode, _tile) {
            document.getElementById('depositProvider').value = providerCode || '';
            // Update the visible PaymentMethod hidden too, in case picker
            // came from a different tile than what's currently selected.
            if (method) document.getElementById('paymentMethod').value = method;
            depositForm.submit();
        };
    </script>
}
