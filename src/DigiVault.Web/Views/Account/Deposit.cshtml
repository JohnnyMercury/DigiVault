@model DepositViewModel
@{
    ViewData["Title"] = "Пополнение баланса";
    var isAdmin = User.IsInRole("Admin");
}

<style>
    .deposit-page {
        max-width: 520px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .deposit-card {
        background: linear-gradient(145deg, #1f1f3a 0%, #161630 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .deposit-title {
        font-size: 1.4rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .deposit-balance {
        background: rgba(102, 126, 234, 0.1);
        border: 1px solid rgba(102, 126, 234, 0.2);
        border-radius: 14px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .deposit-balance i { font-size: 1.25rem; color: #667eea; }
    .deposit-balance-text { font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); }
    .deposit-balance-value { font-weight: 700; color: white; font-size: 1.15rem; }

    .deposit-admin-badge {
        background: rgba(34, 197, 94, 0.1);
        border: 1px solid rgba(34, 197, 94, 0.25);
        border-radius: 12px;
        padding: 0.85rem 1.25rem;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.7);
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }
    .deposit-admin-badge i { color: #22c55e; font-size: 1rem; }

    .deposit-label {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.6rem;
        color: rgba(255, 255, 255, 0.8);
    }

    .deposit-input-wrap {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        margin-bottom: 0.5rem;
        gap: 0.5rem;
        transition: border-color 0.2s ease;
    }
    .deposit-input-wrap:focus-within {
        border-color: rgba(102, 126, 234, 0.5);
    }

    .deposit-input-wrap .currency { color: rgba(255, 255, 255, 0.4); font-size: 1.15rem; font-weight: 600; }

    .deposit-input-wrap input {
        flex-grow: 1;
        background: transparent;
        border: none;
        color: white;
        font-size: 1.15rem;
        font-weight: 600;
    }
    .deposit-input-wrap input:focus { outline: none; }
    .deposit-input-wrap input::placeholder { color: rgba(255, 255, 255, 0.25); }

    .quick-amounts {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1.75rem;
        margin-top: 0.75rem;
    }

    .quick-btn {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 0.55rem 1.1rem;
        color: white;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .quick-btn:hover {
        border-color: rgba(102, 126, 234, 0.4);
        background: rgba(102, 126, 234, 0.1);
    }

    .deposit-submit {
        width: 100%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 12px;
        padding: 0.95rem;
        color: white;
        font-size: 1.05rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }
    .deposit-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.3);
    }
    .deposit-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
        box-shadow: none;
    }

    .deposit-back {
        display: block;
        text-align: center;
        margin-top: 1.25rem;
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.85rem;
        text-decoration: none;
        transition: color 0.2s ease;
    }
    .deposit-back:hover { color: rgba(255, 255, 255, 0.8); }

    /* Payment methods */
    .deposit-pay-methods {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .deposit-pay-method {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 0.85rem 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .deposit-pay-method:hover:not(.disabled) {
        border-color: rgba(102, 126, 234, 0.3);
        background: rgba(102, 126, 234, 0.05);
    }
    .deposit-pay-method.selected {
        border-color: #667eea;
        background: rgba(102, 126, 234, 0.08);
    }
    .deposit-pay-method.disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .deposit-pay-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .deposit-pay-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        color: white;
    }

    .deposit-pay-name {
        font-weight: 600;
        font-size: 0.9rem;
        color: white;
    }
    .deposit-pay-desc {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.45);
        margin-top: 1px;
    }

    .deposit-pay-badge {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
    }
    .deposit-pay-badge.soon {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.4);
    }
    .deposit-pay-badge.active {
        background: rgba(34, 197, 94, 0.15);
        color: #22c55e;
    }

    .deposit-pay-radio {
        width: 20px;
        height: 20px;
        border-radius: 50%;
        border: 2px solid rgba(255, 255, 255, 0.2);
        transition: all 0.2s ease;
        flex-shrink: 0;
    }
    .deposit-pay-radio.active {
        border-color: #667eea;
        background: radial-gradient(circle, #667eea 40%, transparent 45%);
    }

    .deposit-pay-right {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
</style>

<div class="deposit-page">
    <div class="deposit-card">
        <div class="deposit-title">
            <i class="bi bi-plus-circle"></i>
            Пополнение баланса
        </div>

        <div class="deposit-balance">
            <i class="bi bi-wallet2"></i>
            <div>
                <div class="deposit-balance-text">Текущий баланс</div>
                <div class="deposit-balance-value">@Model.CurrentBalance.ToString("N0") ₽</div>
            </div>
        </div>

        @if (isAdmin)
        {
            <div class="deposit-admin-badge">
                <i class="bi bi-shield-check"></i>
                <span>Админ-режим: начисление средств без оплаты</span>
            </div>
        }

        <form asp-action="Deposit" method="post" id="depositForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="deposit-label">Сумма пополнения</div>
            <div class="deposit-input-wrap">
                <span class="currency">₽</span>
                <input asp-for="Amount" placeholder="0" type="number" min="1" step="1" required />
            </div>
            <span asp-validation-for="Amount" class="text-danger small d-block"></span>

            <div class="quick-amounts">
                <button type="button" class="quick-btn" data-amount="100">100 ₽</button>
                <button type="button" class="quick-btn" data-amount="500">500 ₽</button>
                <button type="button" class="quick-btn" data-amount="1000">1 000 ₽</button>
                <button type="button" class="quick-btn" data-amount="5000">5 000 ₽</button>
                <button type="button" class="quick-btn" data-amount="10000">10 000 ₽</button>
            </div>

            <div class="deposit-label">Способ оплаты</div>
            <div class="deposit-pay-methods">
                @if (isAdmin)
                {
                    <div class="deposit-pay-method selected" data-method="admin" onclick="selectDepositMethod(this)">
                        <div class="deposit-pay-left">
                            <div class="deposit-pay-icon" style="background: linear-gradient(135deg, #22c55e, #16a34a);">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <div>
                                <div class="deposit-pay-name">Админ-начисление</div>
                                <div class="deposit-pay-desc">Мгновенное зачисление без оплаты</div>
                            </div>
                        </div>
                        <div class="deposit-pay-right">
                            <span class="deposit-pay-badge active">Доступно</span>
                            <div class="deposit-pay-radio active"></div>
                        </div>
                    </div>
                }

                <div class="deposit-pay-method disabled" data-method="card" onclick="selectDepositMethod(this)">
                    <div class="deposit-pay-left">
                        <div class="deposit-pay-icon" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                            <i class="bi bi-credit-card"></i>
                        </div>
                        <div>
                            <div class="deposit-pay-name">Банковская карта</div>
                            <div class="deposit-pay-desc">Visa, MasterCard, МИР</div>
                        </div>
                    </div>
                    <div class="deposit-pay-right">
                        <span class="deposit-pay-badge soon">Скоро</span>
                        <div class="deposit-pay-radio"></div>
                    </div>
                </div>

                <div class="deposit-pay-method disabled" data-method="sbp" onclick="selectDepositMethod(this)">
                    <div class="deposit-pay-left">
                        <div class="deposit-pay-icon" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                            <i class="bi bi-lightning-charge"></i>
                        </div>
                        <div>
                            <div class="deposit-pay-name">СБП</div>
                            <div class="deposit-pay-desc">Система быстрых платежей</div>
                        </div>
                    </div>
                    <div class="deposit-pay-right">
                        <span class="deposit-pay-badge soon">Скоро</span>
                        <div class="deposit-pay-radio"></div>
                    </div>
                </div>

                <div class="deposit-pay-method disabled" data-method="qr" onclick="selectDepositMethod(this)">
                    <div class="deposit-pay-left">
                        <div class="deposit-pay-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                            <i class="bi bi-qr-code"></i>
                        </div>
                        <div>
                            <div class="deposit-pay-name">QR-код</div>
                            <div class="deposit-pay-desc">Оплата по QR-коду</div>
                        </div>
                    </div>
                    <div class="deposit-pay-right">
                        <span class="deposit-pay-badge soon">Скоро</span>
                        <div class="deposit-pay-radio"></div>
                    </div>
                </div>
            </div>

            <input type="hidden" name="PaymentMethod" id="paymentMethod" value="@(isAdmin ? "admin" : "")" />

            <button type="submit" class="deposit-submit" id="depositBtn" @(isAdmin ? "" : "disabled")>
                <i class="bi bi-check-circle"></i>
                <span id="depositBtnText">@(isAdmin ? "Начислить" : "Пополнить")</span>
            </button>
        </form>

        <a href="/Account/Dashboard" class="deposit-back">
            <i class="bi bi-arrow-left me-1"></i> Вернуться в личный кабинет
        </a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('.quick-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.getElementById('Amount').value = this.dataset.amount;
            });
        });

        function selectDepositMethod(el) {
            if (el.classList.contains('disabled')) return;

            document.querySelectorAll('.deposit-pay-method').forEach(m => {
                m.classList.remove('selected');
                var radio = m.querySelector('.deposit-pay-radio');
                if (radio) radio.classList.remove('active');
            });

            el.classList.add('selected');
            var radio = el.querySelector('.deposit-pay-radio');
            if (radio) radio.classList.add('active');

            document.getElementById('paymentMethod').value = el.dataset.method;
            document.getElementById('depositBtn').disabled = false;
        }
    </script>
}
