@model OrderViewModel
@{
    ViewData["Title"] = $"Заказ {Model.OrderNumber}";
    // Use DigiVault layout (defined in _ViewStart). The partial below renders
    // structured delivery payload — same look/feel for user cabinet and the
    // admin "view as user" page.
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Profile" class="text-primary">Профиль</a></li>
            <li class="breadcrumb-item"><a asp-action="Orders" class="text-primary">Заказы</a></li>
            <li class="breadcrumb-item active">@Model.OrderNumber</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card bg-dark border-secondary mb-4">
                <div class="card-header border-secondary d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-box me-2"></i>Товары в заказе</h5>
                    <span class="badge bg-@Model.StatusClass">@Model.StatusName</span>
                </div>
                <div class="card-body">
                    @foreach (var item in Model.Items)
                    {
                        <div class="order-item-row">
                            <div class="d-flex align-items-start gap-3">
                                <div class="flex-shrink-0">
                                    @if (item.ImageUrl != null)
                                    {
                                        <img src="@item.ImageUrl" alt="@item.ProductName"
                                             style="width: 80px; height: 80px; object-fit: cover; border-radius: 12px;">
                                    }
                                    else
                                    {
                                        <div class="bg-secondary d-flex align-items-center justify-content-center"
                                             style="width: 80px; height: 80px; border-radius: 12px;">
                                            <i class="bi bi-image text-muted fs-3"></i>
                                        </div>
                                    }
                                </div>
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <h6 class="mb-1">@item.ProductName</h6>
                                    <div class="text-muted small mb-2">
                                        @item.Quantity × @item.UnitPrice.ToString("N0") ₽ =
                                        <span class="text-primary fw-bold">@item.TotalPrice.ToString("N0") ₽</span>
                                    </div>
                                </div>
                            </div>
                            @await Html.PartialAsync("_DeliveryPayload", item)
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card bg-dark border-secondary">
                <div class="card-header border-secondary">
                    <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Информация о заказе</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="text-muted small">Номер заказа</div>
                        <code>@Model.OrderNumber</code>
                    </div>
                    @{
                        string IsoUtc(DateTime dt) => DateTime.SpecifyKind(dt, DateTimeKind.Utc).ToString("o");
                    }
                    <div class="mb-3">
                        <div class="text-muted small">Дата заказа</div>
                        <div><time data-utc="@IsoUtc(Model.CreatedAt)" data-fmt="datetime-short">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</time></div>
                    </div>
                    @if (Model.CompletedAt.HasValue)
                    {
                        <div class="mb-3">
                            <div class="text-muted small">Выполнен</div>
                            <div><time data-utc="@IsoUtc(Model.CompletedAt.Value)" data-fmt="datetime-short">@Model.CompletedAt.Value.ToString("dd.MM.yyyy HH:mm")</time></div>
                        </div>
                    }
                    <hr class="border-secondary">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-5">Итого</span>
                        <span class="fs-4 fw-bold text-primary">@Model.TotalAmount.ToString("N0") ₽</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .order-item-row { padding-bottom: 1.5rem; margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .order-item-row:last-child { padding-bottom: 0; margin-bottom: 0; border-bottom: none; }
</style>

@section Scripts {
    <script>
        // Single delegated handler for all .code-copy buttons in delivery payloads.
        document.addEventListener('click', function(e) {
            const btn = e.target.closest('.code-copy');
            if (!btn) return;
            const value = btn.dataset.value;
            if (!value) return;
            navigator.clipboard.writeText(value).then(() => {
                btn.classList.add('copied');
                const span = btn.querySelector('span');
                const prev = span ? span.textContent : '';
                if (span) span.textContent = 'Скопировано';
                setTimeout(() => {
                    btn.classList.remove('copied');
                    if (span) span.textContent = prev;
                }, 1500);
            });
        });

        // Auto-refresh page if any item is still in Pending state — fulfilment
        // happens within ~30s, so we poll once after 8s to pick up the result.
        (function() {
            const hasPending = document.querySelector('.dpayload.pending');
            if (hasPending) setTimeout(() => location.reload(), 8000);
        })();
    </script>
}
