@{
    ViewData["Title"] = "Пополнение Steam — Key Zona";

    const decimal MinAmount = 100m;
    const decimal MaxAmount = 15000m;
    const decimal StepAmount = 50m;
    const decimal DefaultAmount = 1000m;
    const decimal Bonus = 0.10m; // +10% на Steam

    var avgRating = ViewBag.ReviewsAverage is double avg ? avg : 4.9;
    var reviewsCount = ViewBag.ReviewsCount is int rc ? rc : 0;
}

<style>
    .steam-page { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem 4rem; }

    /* Hero */
    .steam-hero {
        background: linear-gradient(135deg, rgba(27,40,56,0.9), rgba(102,192,244,0.18)),
                    radial-gradient(circle at 20% 20%, rgba(102,192,244,0.25), transparent 55%);
        border: 1px solid rgba(102,192,244,0.3);
        border-radius: 24px;
        padding: 2.4rem 2rem;
        text-align: center;
        position: relative; overflow: hidden;
    }
    .steam-hero::before {
        content: ''; position: absolute; inset: -50% -10% auto auto; width: 360px; height: 360px;
        background: radial-gradient(circle, rgba(102,192,244,0.35), transparent 60%);
        filter: blur(20px); pointer-events: none;
    }
    .steam-eyebrow {
        display: inline-flex; align-items: center; gap: 0.45rem;
        padding: 0.35rem 0.85rem; border-radius: 999px;
        background: rgba(102,192,244,0.18); color: #66c0f4;
        font-size: 0.78rem; font-weight: 600;
    }
    .steam-hero-title {
        font-size: clamp(1.8rem, 4vw, 2.8rem); margin: 0.7rem 0 0.4rem;
        background: linear-gradient(135deg, #fff, #66c0f4);
        -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    }
    .steam-hero-sub { color: rgba(255,255,255,0.7); font-size: 1rem; max-width: 580px; margin: 0 auto; }

    /* Layout */
    .steam-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 1.5rem; margin-top: 1.5rem; }
    @@media (max-width: 900px) { .steam-grid { grid-template-columns: 1fr; } }

    .steam-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 18px;
        padding: 1.5rem 1.6rem;
    }
    .steam-card-title {
        display: flex; align-items: center; gap: 0.55rem;
        font-size: 1.05rem; font-weight: 700; color: #fff;
        margin: 0 0 1rem;
    }
    .steam-card-title i { color: #66c0f4; }

    /* Slider */
    .steam-amount-display {
        display: flex; align-items: baseline; gap: 0.6rem;
        font-size: 2.4rem; font-weight: 800; color: #fff;
        margin-bottom: 0.5rem;
    }
    .steam-amount-display .pay { color: #66c0f4; }
    .steam-amount-display .arrow { color: rgba(255,255,255,0.35); font-size: 1.4rem; }
    .steam-amount-display .get { color: #22c55e; }
    .steam-amount-bonus {
        display: inline-flex; align-items: center; gap: 0.3rem;
        font-size: 0.8rem; padding: 0.25rem 0.65rem;
        background: rgba(34,197,94,0.15); color: #22c55e;
        border-radius: 6px; font-weight: 600;
        margin-bottom: 1rem;
    }

    .steam-slider-wrap { padding: 0.5rem 0 1rem; position: relative; }
    .steam-slider {
        -webkit-appearance: none; appearance: none;
        width: 100%; height: 8px;
        background: rgba(255,255,255,0.08);
        border-radius: 999px; outline: none;
    }
    .steam-slider::-webkit-slider-runnable-track {
        height: 8px; border-radius: 999px;
        background: linear-gradient(to right, #66c0f4 var(--fill, 50%), rgba(255,255,255,0.08) var(--fill, 50%));
    }
    .steam-slider::-webkit-slider-thumb {
        -webkit-appearance: none; appearance: none;
        width: 22px; height: 22px; border-radius: 50%;
        background: #fff; border: 3px solid #66c0f4;
        margin-top: -7px; cursor: pointer;
        box-shadow: 0 4px 14px rgba(102,192,244,0.5);
    }
    .steam-slider::-moz-range-track { height: 8px; border-radius: 999px;
        background: linear-gradient(to right, #66c0f4 var(--fill, 50%), rgba(255,255,255,0.08) var(--fill, 50%)); }
    .steam-slider::-moz-range-thumb {
        width: 22px; height: 22px; border-radius: 50%;
        background: #fff; border: 3px solid #66c0f4; cursor: pointer;
        box-shadow: 0 4px 14px rgba(102,192,244,0.5);
    }
    .steam-slider-bounds {
        display: flex; justify-content: space-between;
        margin-top: 0.5rem; font-size: 0.78rem; color: rgba(255,255,255,0.4);
    }

    .steam-quick-row { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.85rem; }
    .steam-quick-btn {
        padding: 0.5rem 0.95rem;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        color: #fff; border-radius: 10px;
        font-size: 0.85rem; font-weight: 600; cursor: pointer;
        transition: background .15s, border-color .15s;
    }
    .steam-quick-btn:hover { background: rgba(102,192,244,0.1); border-color: rgba(102,192,244,0.4); }
    .steam-quick-btn.active { background: rgba(102,192,244,0.15); border-color: #66c0f4; color: #66c0f4; }

    /* Login input */
    .steam-input-label { display: block; font-size: 0.85rem; font-weight: 600; color: rgba(255,255,255,0.85); margin-bottom: 0.4rem; }
    .steam-input {
        width: 100%; padding: 0.85rem 1rem;
        background: rgba(255,255,255,0.04);
        border: 1.5px solid rgba(255,255,255,0.08);
        color: #fff; border-radius: 10px;
        font-size: 0.95rem; transition: border-color .15s;
    }
    .steam-input:focus { outline: none; border-color: rgba(102,192,244,0.5); }
    .steam-input::placeholder { color: rgba(255,255,255,0.3); }
    .steam-input-hint { font-size: 0.78rem; color: rgba(255,255,255,0.4); margin-top: 0.3rem; }

    /* Right column — summary card */
    .steam-summary { display: flex; flex-direction: column; gap: 0.85rem; }
    .steam-summary-row {
        display: flex; justify-content: space-between; align-items: baseline;
        padding-bottom: 0.7rem; border-bottom: 1px dashed rgba(255,255,255,0.07);
    }
    .steam-summary-row:last-of-type { border-bottom: none; padding-bottom: 0; }
    .steam-summary-label { color: rgba(255,255,255,0.55); font-size: 0.88rem; }
    .steam-summary-value { color: #fff; font-weight: 600; font-size: 1.05rem; }
    .steam-summary-value.accent { color: #66c0f4; }
    .steam-summary-value.bonus { color: #22c55e; }

    .steam-error {
        background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5; border-radius: 10px;
        padding: 0.7rem 0.9rem; font-size: 0.85rem;
        display: none; margin-bottom: 0.8rem;
    }
    .steam-error.visible { display: flex; align-items: center; gap: 0.5rem; }

    .steam-cta {
        width: 100%; margin-top: 0.75rem;
        padding: 1rem;
        background: linear-gradient(135deg, #66c0f4, #1b9adf);
        color: #fff; font-weight: 700; font-size: 1.05rem;
        border: none; border-radius: 12px; cursor: pointer;
        transition: transform .15s, box-shadow .2s;
        display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    }
    .steam-cta:hover { transform: translateY(-1px); box-shadow: 0 12px 30px rgba(102,192,244,0.4); }
    .steam-cta:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }

    .steam-trust {
        display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 0.85rem;
        font-size: 0.78rem; color: rgba(255,255,255,0.5);
    }
    .steam-trust span { display: inline-flex; align-items: center; gap: 0.3rem; }
    .steam-trust i { color: #22c55e; }

    /* FAQ */
    .steam-section { margin-top: 2rem; }
    .steam-section-title { font-size: 1.5rem; font-weight: 700; color: #fff; margin: 0 0 1.2rem; text-align: center; }
    .faq-list { display: flex; flex-direction: column; gap: 0.7rem; max-width: 820px; margin: 0 auto; }
    .faq-item {
        background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 12px; overflow: hidden;
    }
    .faq-q {
        display: flex; justify-content: space-between; align-items: center; gap: 0.85rem;
        padding: 1rem 1.25rem; cursor: pointer; font-weight: 600; color: #fff;
        font-size: 0.95rem;
    }
    .faq-q i { transition: transform .2s; color: #66c0f4; }
    .faq-item.open .faq-q i { transform: rotate(180deg); }
    .faq-a { max-height: 0; overflow: hidden; transition: max-height .25s ease; }
    .faq-item.open .faq-a { max-height: 400px; }
    .faq-a-inner { padding: 0 1.25rem 1rem; color: rgba(255,255,255,0.7); font-size: 0.9rem; line-height: 1.55; }

    /* Reviews mini */
    .steam-reviews-row {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 0.85rem; margin-top: 1rem;
    }
    .steam-review {
        background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);
        border-radius: 14px; padding: 1.1rem;
    }
    .steam-review-head { display: flex; align-items: center; gap: 0.65rem; margin-bottom: 0.6rem; }
    .steam-review-avatar {
        width: 38px; height: 38px; border-radius: 50%;
        background: linear-gradient(135deg, #66c0f4, #1b9adf);
        color: #fff; display: flex; align-items: center; justify-content: center;
        font-weight: 700;
    }
    .steam-review-name { color: #fff; font-weight: 600; font-size: 0.9rem; }
    .steam-review-stars { color: #fbbf24; font-size: 0.78rem; }
    .steam-review-text { color: rgba(255,255,255,0.7); font-size: 0.88rem; line-height: 1.5; }
    .steam-review-date { color: rgba(255,255,255,0.35); font-size: 0.72rem; margin-top: 0.5rem; }
    .steam-rating-summary {
        display: flex; align-items: center; justify-content: center; gap: 0.5rem;
        margin-bottom: 0.5rem; color: rgba(255,255,255,0.7);
    }
    .steam-rating-summary .big { color: #fbbf24; font-size: 1.3rem; font-weight: 700; }
</style>

<div class="steam-page">
    <!-- Hero -->
    <div class="steam-hero">
        <div class="steam-eyebrow"><i class="bi bi-shield-check"></i> Безопасное пополнение через ЕнотПэй</div>
        <h1 class="steam-hero-title">Пополнить Steam с бонусом +10%</h1>
        <p class="steam-hero-sub">
            Закидывайте от 100 до 15 000 ₽ — мы добавляем 10% сверху на ваш Steam-кошелёк.
            Логин, никаких паролей и никакого доступа к аккаунту.
        </p>
    </div>

    <div class="steam-grid">
        <!-- Left: form -->
        <div class="steam-card">
            <h2 class="steam-card-title"><i class="bi bi-cash-coin"></i> Сумма пополнения</h2>

            <div class="steam-amount-display">
                <span class="pay" id="payDisplay">@DefaultAmount.ToString("N0") ₽</span>
                <span class="arrow"><i class="bi bi-arrow-right"></i></span>
                <span class="get" id="getDisplay">@Math.Round(DefaultAmount * (1m + Bonus), 0).ToString("N0") ₽</span>
            </div>
            <span class="steam-amount-bonus"><i class="bi bi-stars"></i> Бонус +10% всегда</span>

            <div class="steam-slider-wrap">
                <input id="amountSlider" class="steam-slider" type="range"
                       min="@MinAmount" max="@MaxAmount" step="@StepAmount" value="@DefaultAmount" />
                <div class="steam-slider-bounds">
                    <span>@MinAmount.ToString("N0") ₽</span>
                    <span>@MaxAmount.ToString("N0") ₽</span>
                </div>
            </div>

            <div class="steam-quick-row" id="quickRow">
                @foreach (var v in new[] { 300m, 500m, 1000m, 2500m, 5000m, 10000m })
                {
                    <button type="button" class="steam-quick-btn" data-amount="@v">@v.ToString("N0") ₽</button>
                }
            </div>

            <div style="margin-top: 1.5rem;">
                <label class="steam-input-label" for="steamLogin">Логин Steam</label>
                <input id="steamLogin" type="text" class="steam-input"
                       placeholder="например, gabe_n_2024" autocomplete="off" />
                <div class="steam-input-hint">
                    <i class="bi bi-info-circle"></i>
                    Это ваш публичный логин для входа в Steam. Пароль и код подтверждения мы НЕ запрашиваем.
                </div>
            </div>

            <div id="emailBlock" style="margin-top: 1.25rem; display: none;">
                <label class="steam-input-label" for="steamEmail">Email для чека</label>
                <input id="steamEmail" type="email" class="steam-input" placeholder="example@@email.com" />
                <div class="steam-input-hint">На этот адрес мы пришлём подтверждение оплаты и номер заказа.</div>
            </div>

            <div style="margin-top: 1.5rem;">
                <label class="steam-input-label">Способ оплаты</label>
                @{
                    var __steamTiles = new DigiVault.Web.Models.Payment.PaymentTilesViewModel
                    {
                        ShowBalance  = false,
                        SelectedCode = "card",
                        OnSelectJs   = "selectPayMethod"
                    };
                }
                <partial name="_PaymentMethodTiles" model="__steamTiles" />
            </div>
        </div>

        <!-- Right: summary -->
        <div class="steam-card">
            <h2 class="steam-card-title"><i class="bi bi-receipt"></i> Детали заказа</h2>
            <div class="steam-summary">
                <div class="steam-summary-row">
                    <span class="steam-summary-label">Вы платите</span>
                    <span class="steam-summary-value accent" id="summaryPay">@DefaultAmount.ToString("N0") ₽</span>
                </div>
                <div class="steam-summary-row">
                    <span class="steam-summary-label">Бонус</span>
                    <span class="steam-summary-value bonus" id="summaryBonus">+@Math.Round(DefaultAmount * Bonus, 0).ToString("N0") ₽</span>
                </div>
                <div class="steam-summary-row">
                    <span class="steam-summary-label">Зачислится на Steam</span>
                    <span class="steam-summary-value" id="summaryGet">@Math.Round(DefaultAmount * (1m + Bonus), 0).ToString("N0") ₽</span>
                </div>
            </div>

            <div class="steam-error" id="steamError"><i class="bi bi-exclamation-triangle-fill"></i> <span></span></div>

            <button type="button" class="steam-cta" id="steamPayBtn" onclick="submitSteamPurchase()">
                <i class="bi bi-shield-lock"></i>
                <span>Оплатить @DefaultAmount.ToString("N0") ₽</span>
            </button>

            <div class="steam-trust">
                <span><i class="bi bi-check-circle-fill"></i> SSL · 3D-Secure</span>
                <span><i class="bi bi-check-circle-fill"></i> Без доступа к аккаунту</span>
                <span><i class="bi bi-check-circle-fill"></i> Возврат в случае ошибки</span>
            </div>
        </div>
    </div>

    <!-- FAQ -->
    <div class="steam-section">
        <h2 class="steam-section-title">Частые вопросы</h2>
        <div class="faq-list">
            <div class="faq-item open">
                <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
                    <span>Как быстро поступят деньги на Steam?</span>
                    <i class="bi bi-chevron-down"></i>
                </div>
                <div class="faq-a"><div class="faq-a-inner">
                    После оплаты ваш заказ попадает к оператору на финальную проверку. На этом этапе мы подтверждаем ваш Steam-логин в Telegram (5–10 минут) — это защита от автоматических ботов и фишинга. Сразу после подтверждения деньги уходят на ваш аккаунт.
                </div></div>
            </div>
            <div class="faq-item">
                <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
                    <span>Что значит «бонус +10%»?</span>
                    <i class="bi bi-chevron-down"></i>
                </div>
                <div class="faq-a"><div class="faq-a-inner">
                    Если оплачиваете 1 000 ₽ — мы зачисляем на Steam 1 100 ₽. Бонус накидывается всегда, на любую сумму от 100 до 15 000 ₽. Никаких скрытых комиссий и условий.
                </div></div>
            </div>
            <div class="faq-item">
                <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
                    <span>Почему нужно писать в Telegram после оплаты?</span>
                    <i class="bi bi-chevron-down"></i>
                </div>
                <div class="faq-a"><div class="faq-a-inner">
                    Steam в 2024 году усилил антифрод по автоматическим пополнениям — массовые роботы блокируются на стороне Valve. Мы зачисляем средства вручную через одобренный поток платежей: оператор подтверждает ваш ник в Telegram и закрывает заказ. Это занимает буквально пару минут, зато аккаунт остаётся в безопасности.
                </div></div>
            </div>
            <div class="faq-item">
                <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
                    <span>Какие данные вы запрашиваете?</span>
                    <i class="bi bi-chevron-down"></i>
                </div>
                <div class="faq-a"><div class="faq-a-inner">
                    Только публичный логин Steam — тот же, по которому вы заходите в клиент. Пароль, код Steam Guard, секретные вопросы — НЕ нужны и НЕ запрашиваются. Если кто-то просит их — это мошенник, не мы.
                </div></div>
            </div>
            <div class="faq-item">
                <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
                    <span>Какие минимальная и максимальная суммы?</span>
                    <i class="bi bi-chevron-down"></i>
                </div>
                <div class="faq-a"><div class="faq-a-inner">
                    Минимум — 100 ₽, максимум — 15 000 ₽ за один платёж. Можно оформить несколько заказов подряд, лимит на количество не ограничен. Шаг слайдера — 50 ₽.
                </div></div>
            </div>
            <div class="faq-item">
                <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
                    <span>Что если деньги не пришли?</span>
                    <i class="bi bi-chevron-down"></i>
                </div>
                <div class="faq-a"><div class="faq-a-inner">
                    Пишите в Telegram-поддержку — мы оперативно либо зачислим, либо вернём средства. Каждый заказ имеет уникальный номер; назовите его оператору, и мы найдём вашу транзакцию за секунду.
                </div></div>
            </div>
        </div>
    </div>

    <!-- Reviews -->
    <div class="steam-section">
        <h2 class="steam-section-title">Отзывы покупателей</h2>
        <div class="steam-rating-summary">
            <span class="big">★ @avgRating.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)</span>
            <span>средняя оценка @(reviewsCount > 0 ? $"({reviewsCount} отзывов)" : "")</span>
        </div>
        <div class="steam-reviews-row">
            @{
                var fakeReviews = new[]
                {
                    ("Дмитрий П.",   "Закинул 1000 ₽, пришло 1100 ₽ за 6 минут. Оператор в TG ответил сразу.", 5, "вчера"),
                    ("Алексей К.",   "Уже третий раз пополняю, всё четко. Бонус +10% — реально ощутимо на больших суммах.", 5, "2 дня назад"),
                    ("Влад М.",     "Был немного скептичен из-за «проверки безопасности», но всё прошло за 8 минут. В Telegram всё объяснили.", 5, "3 дня назад"),
                    ("Игорь С.",    "Работает 24/7, проверял в 3 ночи — оператор ответил за минуту. Цены лучшие.", 5, "4 дня назад"),
                    ("Никита А.",   "Бонус накапливается даже на минимальных суммах. Закинул 100 ₽ — пришло 110. Топ.", 4, "неделю назад"),
                    ("Олег Р.",     "Закинул 5000, получил 5500. Ушло 7 минут от оплаты до зачисления. Рекомендую.", 5, "неделю назад"),
                    ("Сергей В.",   "Удобный слайдер, видно сразу сколько придёт. Не нужно считать в голове.", 5, "9 дней назад"),
                    ("Артём Д.",    "Раньше переводил через сторонних, тут процесс прозрачнее и оператор адекватный.", 5, "12 дней назад")
                };
            }
            @foreach (var (name, text, stars, date) in fakeReviews)
            {
                <div class="steam-review">
                    <div class="steam-review-head">
                        <div class="steam-review-avatar">@name.Substring(0, 1)</div>
                        <div>
                            <div class="steam-review-name">@name</div>
                            <div class="steam-review-stars">@(new string('★', stars))@(new string('☆', 5 - stars))</div>
                        </div>
                    </div>
                    <div class="steam-review-text">@text</div>
                    <div class="steam-review-date">@date</div>
                </div>
            }
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<script>
(function () {
    const slider     = document.getElementById('amountSlider');
    const payDisp    = document.getElementById('payDisplay');
    const getDisp    = document.getElementById('getDisplay');
    const sumPay     = document.getElementById('summaryPay');
    const sumBonus   = document.getElementById('summaryBonus');
    const sumGet     = document.getElementById('summaryGet');
    const cta        = document.getElementById('steamPayBtn');
    const errBox     = document.getElementById('steamError');
    const isAuth     = @((User.Identity?.IsAuthenticated == true).ToString().ToLowerInvariant());
    const emailBlock = document.getElementById('emailBlock');
    if (!isAuth) emailBlock.style.display = 'block';

    const min = @MinAmount, max = @MaxAmount, bonus = @Bonus;

    function fmt(n) { return Math.round(n).toLocaleString('ru-RU'); }

    function update() {
        const v = parseInt(slider.value, 10);
        const credit = Math.round(v * (1 + bonus));
        const bonusValue = credit - v;
        payDisp.textContent = fmt(v) + ' ₽';
        getDisp.textContent = fmt(credit) + ' ₽';
        sumPay.textContent  = fmt(v) + ' ₽';
        sumBonus.textContent = '+' + fmt(bonusValue) + ' ₽';
        sumGet.textContent  = fmt(credit) + ' ₽';
        cta.querySelector('span').textContent = 'Оплатить ' + fmt(v) + ' ₽';
        const pct = ((v - min) / (max - min)) * 100;
        slider.style.setProperty('--fill', pct + '%');
        // sync quick buttons
        document.querySelectorAll('.steam-quick-btn').forEach(b => {
            b.classList.toggle('active', parseInt(b.dataset.amount, 10) === v);
        });
        window.lastSelectedPrice = v;
    }
    slider.addEventListener('input', update);
    update();

    document.querySelectorAll('.steam-quick-btn').forEach(b => {
        b.addEventListener('click', () => {
            slider.value = b.dataset.amount;
            update();
        });
    });

    function showError(msg) {
        errBox.querySelector('span').textContent = msg;
        errBox.classList.add('visible');
    }
    function clearError() {
        errBox.classList.remove('visible');
    }

    window.submitSteamPurchase = async function () {
        clearError();
        const amount = parseInt(slider.value, 10);
        const login  = document.getElementById('steamLogin').value.trim();
        const method = window.lastSelectedPaymentMethod || 'card';
        if (!login) return showError('Введите ваш Steam-логин');
        if (login.length < 3) return showError('Логин слишком короткий');
        if (amount < min) return showError('Минимум — ' + min + ' ₽');
        if (amount > max) return showError('Максимум — ' + max + ' ₽');
        if (method === 'qr' || method === 'p2p')
            return showError('Этот метод оплаты пока не подключён. Выберите Карту или СБП.');

        let email = null;
        if (!isAuth) {
            email = document.getElementById('steamEmail').value.trim();
            if (!email) return showError('Введите Email для чека');
            if (!/^[^@@\s]+@@[^@@\s]+\.[^@@\s]+$/.test(email))
                return showError('Введите корректный Email');
        }

        cta.disabled = true;
        cta.querySelector('span').textContent = 'Создаём платёж…';

        try {
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            const resp = await fetch('/Catalog/PurchaseSteam', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': tokenInput ? tokenInput.value : ''
                },
                body: JSON.stringify({
                    Amount: amount,
                    SteamLogin: login,
                    PaymentMethod: method,
                    Email: email
                })
            });
            const data = await resp.json();
            if (!data.success) {
                showError(data.errorMessage || 'Не удалось создать платёж');
                cta.disabled = false;
                cta.querySelector('span').textContent = 'Оплатить ' + fmt(amount) + ' ₽';
                return;
            }
            if (data.redirectUrl) {
                window.location.href = data.redirectUrl;
            } else {
                window.location.href = '/Account/Orders';
            }
        } catch (e) {
            showError('Ошибка сети. Попробуйте ещё раз.');
            cta.disabled = false;
            cta.querySelector('span').textContent = 'Оплатить ' + fmt(amount) + ' ₽';
        }
    };
})();
</script>
