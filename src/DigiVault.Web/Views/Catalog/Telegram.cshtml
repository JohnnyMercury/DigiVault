@using DigiVault.Core.Entities
@{
    var premiumCard = ViewBag.PremiumCard as GiftCard;
    var premiumProducts = ViewBag.PremiumProducts as List<GameProduct> ?? new List<GameProduct>();
    ViewData["Title"] = "Telegram Premium";
}

<style>
    .game-page {
        display: flex;
        gap: 1.5rem;
        padding: 1rem 0;
    }

    .game-sidebar-spacer {
        width: 280px;
        flex-shrink: 0;
    }

    .payment-sidebar-spacer {
        width: 300px;
        flex-shrink: 0;
    }

    @@media (max-width: 1200px) {
        .game-sidebar-spacer { display: none; }
    }

    @@media (max-width: 992px) {
        .payment-sidebar-spacer { display: none; }
    }

    /* Main Content */
    .game-main {
        flex-grow: 1;
        min-width: 0;
    }

    /* Username input */
    .uid-section {
        background: linear-gradient(145deg, #1f1f3a 0%, #161630 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 14px;
        padding: 1.1rem 1.5rem;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: all 0.3s ease;
    }

    .uid-section:focus-within {
        border-color: rgba(42, 171, 238, 0.5);
        box-shadow: 0 0 20px rgba(42, 171, 238, 0.15);
    }

    .uid-input {
        flex-grow: 1;
        background: transparent;
        border: none;
        color: white;
        font-size: 1.05rem;
        padding: 0.5rem 0;
        font-weight: 500;
    }

    .uid-input:focus { outline: none; }
    .uid-input::placeholder { color: rgba(255, 255, 255, 0.35); font-weight: 400; }

    .uid-prefix {
        color: rgba(255, 255, 255, 0.4);
        font-size: 1.1rem;
        font-weight: 600;
    }

    .uid-checkbox {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.9rem;
        cursor: pointer;
        white-space: nowrap;
        font-weight: 500;
    }

    .uid-checkbox input[type="checkbox"] {
        width: 20px;
        height: 20px;
        accent-color: #2AABEE;
        cursor: pointer;
    }

    /* Stars input section */
    .stars-input-wrapper {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-grow: 1;
    }

    .stars-input-wrapper input[type="number"] {
        flex-grow: 1;
        background: transparent;
        border: none;
        color: white;
        font-size: 1.05rem;
        padding: 0.5rem 0;
        font-weight: 500;
        -moz-appearance: textfield;
    }

    .stars-input-wrapper input[type="number"]::-webkit-outer-spin-button,
    .stars-input-wrapper input[type="number"]::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .stars-input-wrapper input[type="number"]:focus { outline: none; }
    .stars-input-wrapper input[type="number"]::placeholder { color: rgba(255, 255, 255, 0.35); font-weight: 400; }

    .stars-icon {
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .stars-price-display {
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.9rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .stars-error {
        display: none;
        background: rgba(239, 68, 68, 0.15);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 10px;
        padding: 0.6rem 1rem;
        margin-top: -0.5rem;
        margin-bottom: 1rem;
        font-size: 0.8rem;
        color: #ef4444;
        line-height: 1.4;
    }

    .stars-error.visible {
        display: block;
    }

    /* Section Title */
    .section-title {
        font-size: 1.15rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: #ffffff;
        letter-spacing: 0.01em;
    }

    /* Product grid */
    .currency-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
    }

    @@media (max-width: 1200px) {
        .currency-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }
    @@media (max-width: 900px) {
        .currency-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }
    @@media (max-width: 576px) {
        .currency-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    .product-item {
        display: flex;
        flex-direction: column;
        cursor: pointer;
    }

    .currency-card {
        background: linear-gradient(145deg, #1e1e38 0%, #161630 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        padding: 0;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        aspect-ratio: 1;
        min-width: 0;
    }

    .currency-card:hover {
        border-color: rgba(42, 171, 238, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    }

    .product-item.selected .currency-card {
        border-color: #22c55e;
        box-shadow: 0 0 20px rgba(34, 197, 94, 0.25);
    }

    .currency-card-selected-badge {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        background: #22c55e;
        color: white;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 600;
        display: none;
        align-items: center;
        gap: 0.2rem;
        z-index: 10;
    }

    .product-item.selected .currency-card-selected-badge {
        display: flex;
    }

    .currency-card-amount {
        position: absolute;
        top: 0.5rem;
        left: 0.5rem;
        background: #2AABEE;
        color: white;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 700;
        z-index: 10;
    }

    .currency-card-image {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0;
    }

    .currency-card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .currency-card-placeholder {
        font-size: 3.5rem;
        opacity: 0.9;
    }

    .product-caption {
        padding: 0.5rem 0.25rem;
        text-align: left;
    }

    .product-caption-price {
        font-size: 1rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 0.1rem;
    }

    .product-caption-name {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.6);
        font-weight: 400;
    }

    .product-caption-old-price {
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.4);
        text-decoration: line-through;
    }

    .product-caption-discount {
        font-size: 0.65rem;
        background: #ef4444;
        color: white;
        padding: 0.1rem 0.3rem;
        border-radius: 3px;
        font-weight: 600;
    }

    /* Payment Sidebar */
    .payment-sidebar {
        width: 300px;
        flex-shrink: 0;
        position: sticky;
        top: 100px;
        height: fit-content;
        align-self: flex-start;
    }

    @@media (max-width: 992px) {
        .game-page { flex-direction: column; }
        .payment-sidebar {
            width: 100%;
            position: relative;
            top: auto;
        }
        .payment-card {
            padding: 1rem;
            border-radius: 14px;
        }
        .payment-total-value {
            font-size: 1.4rem;
        }
    }

    @@media (max-width: 768px) {
        .game-page { padding: 0.5rem 0; gap: 1rem; }
        .section-title { font-size: 1rem; margin-bottom: 0.75rem; }
        .product-section { margin-bottom: 1.5rem; }
    }

    .payment-card {
        background: linear-gradient(145deg, #1f1f3a 0%, #161630 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        padding: 1.5rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .payment-product {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        margin-bottom: 1rem;
    }

    .payment-product-icon {
        width: 50px;
        height: 50px;
        border-radius: 10px;
        background: rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        overflow: hidden;
    }

    .payment-product-icon img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .payment-product-info { flex-grow: 1; }
    .payment-product-name { font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); }
    .payment-product-amount { font-size: 1.1rem; font-weight: 700; }

    .payment-summary { margin-bottom: 1.25rem; }

    .payment-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .payment-summary-label { font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); }
    .payment-summary-value { font-size: 0.85rem; font-weight: 600; }
    .payment-summary-value.discount { color: #ef4444; }

    .payment-summary-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .payment-total-label { font-size: 1rem; font-weight: 600; }
    .payment-total-value { font-size: 1.75rem; font-weight: 800; }

    .payment-button {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #2AABEE 0%, #229ED9 100%);
        border: none;
        border-radius: 14px;
        color: white;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-bottom: 0.75rem;
    }

    .payment-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(42, 171, 238, 0.4);
    }

    .payment-delivery { margin-top: 1rem; }

    .payment-delivery-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }

    .payment-delivery-label { font-size: 0.8rem; color: rgba(255, 255, 255, 0.5); }
    .payment-delivery-value { font-size: 0.8rem; font-weight: 600; }
    .payment-delivery-value.highlight { color: #2AABEE; }

    /* Trust Badge */
    .trust-badge {
        background: linear-gradient(145deg, #1f1f3a 0%, #161630 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        margin-top: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0;
    }

    .trust-badge-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex: 1;
        justify-content: center;
    }

    .trust-badge-icon { font-size: 1.6rem; }

    .trust-badge-text {
        font-size: 0.8rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.3;
    }

    .trust-badge-divider {
        width: 1px;
        height: 2.5rem;
        background: rgba(255, 255, 255, 0.1);
        margin: 0 0.75rem;
    }

    /* Hero title */
    .tg-hero {
        padding: 1.5rem 0 0.5rem;
    }

    .tg-hero-badges {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
    }

    .tg-hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.75rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .tg-hero-badge.blue {
        background: rgba(42, 171, 238, 0.15);
        color: #2AABEE;
    }

    .tg-hero-badge.green {
        background: rgba(34, 197, 94, 0.15);
        color: #22c55e;
    }

    .tg-hero-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 0.25rem;
        line-height: 1.2;
    }

    /* FAQ Section */
    .faq-section {
        padding: 2.5rem 0 1rem;
    }

    .faq-title {
        font-size: 1.35rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 1.25rem;
    }

    .faq-item {
        background: linear-gradient(145deg, #1f1f3a 0%, #161630 100%);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 12px;
        margin-bottom: 0.5rem;
        overflow: hidden;
        transition: border-color 0.3s ease;
    }

    .faq-item:hover {
        border-color: rgba(42, 171, 238, 0.2);
    }

    .faq-question {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        cursor: pointer;
        color: rgba(255, 255, 255, 0.9);
        font-weight: 500;
        font-size: 0.9rem;
        user-select: none;
    }

    .faq-question i {
        color: rgba(42, 171, 238, 0.7);
        font-size: 1rem;
        transition: transform 0.3s ease;
        flex-shrink: 0;
    }

    .faq-item.open .faq-question i {
        transform: rotate(45deg);
    }

    .faq-answer {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease, padding 0.3s ease;
    }

    .faq-item.open .faq-answer {
        max-height: 300px;
    }

    .faq-answer-inner {
        padding: 0 1.25rem 1rem;
        font-size: 0.85rem;
        color: rgba(255, 255, 255, 0.55);
        line-height: 1.6;
    }

    /* Purchase Modal */
    .purchase-overlay {
        display: none;
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(6px);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .purchase-overlay.active { display: flex; }

    .purchase-modal {
        background: linear-gradient(145deg, #1f1f3a 0%, #161630 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        width: 100%;
        max-width: 860px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
    }

    .purchase-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }
    .purchase-modal-header h3 { margin: 0; font-size: 1.1rem; font-weight: 700; color: white; }
    .purchase-modal-close {
        background: none; border: none; color: rgba(255, 255, 255, 0.5); font-size: 1.5rem; cursor: pointer; padding: 0; line-height: 1;
    }

    .purchase-modal-body { display: flex; gap: 2rem; padding: 1.75rem; }
    @@media (max-width: 600px) {
        .purchase-modal-body { flex-direction: column; }
        .purchase-modal-left { width: 100% !important; }
    }

    .purchase-modal-left { width: 220px; flex-shrink: 0; text-align: center; }
    .purchase-modal-image {
        width: 100%; aspect-ratio: 1; border-radius: 14px; overflow: hidden;
        background: rgba(255, 255, 255, 0.05); display: flex; align-items: center; justify-content: center; margin-bottom: 0.75rem;
    }
    .purchase-modal-image img { width: 100%; height: 100%; object-fit: cover; }
    .purchase-modal-image .modal-placeholder { font-size: 3rem; }
    .purchase-modal-product-name { font-size: 1rem; font-weight: 700; color: white; margin-bottom: 0.25rem; }
    .purchase-modal-product-desc { font-size: 0.85rem; color: rgba(255, 255, 255, 0.6); margin-bottom: 0.5rem; }
    .purchase-modal-price-row { font-size: 0.9rem; color: white; font-weight: 600; }
    .purchase-modal-price-row .old-price { text-decoration: line-through; color: rgba(255, 255, 255, 0.4); font-size: 0.8rem; margin-left: 0.25rem; }

    .purchase-modal-right { flex-grow: 1; display: flex; flex-direction: column; gap: 1rem; }

    .modal-label { font-size: 0.85rem; font-weight: 600; color: rgba(255, 255, 255, 0.8); margin-bottom: 0.4rem; }
    .modal-input {
        width: 100%; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px; padding: 0.7rem 1rem; color: white; font-size: 0.9rem;
    }
    .modal-input:focus { outline: none; border-color: rgba(42, 171, 238, 0.5); }
    .modal-input::placeholder { color: rgba(255, 255, 255, 0.3); }
    .modal-hint { font-size: 0.75rem; color: rgba(255, 255, 255, 0.4); margin-top: 0.3rem; }
    .modal-info-banner {
        background: rgba(42, 171, 238, 0.08); border: 1px solid rgba(42, 171, 238, 0.15);
        border-radius: 10px; padding: 0.7rem 0.9rem; font-size: 0.8rem; color: rgba(255, 255, 255, 0.7); line-height: 1.4;
    }
    .modal-info-banner a { color: #2AABEE; }

    .modal-payment-methods { display: flex; flex-direction: column; gap: 0.5rem; }
    .modal-pay-method { display: flex; align-items: center; justify-content: space-between; background: rgba(255, 255, 255, 0.04); border: 2px solid rgba(255, 255, 255, 0.08); border-radius: 12px; padding: 0.75rem 1rem; cursor: pointer; transition: all 0.2s ease; }
    .modal-pay-method:hover:not(.disabled) { border-color: rgba(42, 171, 238, 0.4); }
    .modal-pay-method.selected { border-color: #2AABEE; background: rgba(42, 171, 238, 0.08); }
    .modal-pay-method.disabled { opacity: 0.5; cursor: not-allowed; }
    .modal-pay-method-left { display: flex; align-items: center; gap: 0.75rem; }
    .modal-pay-method-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.1rem; flex-shrink: 0; }
    .modal-pay-method-title { font-size: 0.9rem; font-weight: 600; color: rgba(255, 255, 255, 0.95); }
    .modal-pay-method-desc { font-size: 0.75rem; color: rgba(255, 255, 255, 0.5); margin-top: 0.1rem; }
    .modal-pay-method-right { display: flex; align-items: center; gap: 0.5rem; }
    .modal-pay-badge-instant { font-size: 0.7rem; color: #22c55e; font-weight: 600; }
    .modal-pay-badge-soon { font-size: 0.65rem; background: rgba(255, 255, 255, 0.1); color: rgba(255, 255, 255, 0.5); padding: 0.2rem 0.5rem; border-radius: 6px; }
    .modal-pay-radio { width: 20px; height: 20px; border-radius: 50%; border: 2px solid rgba(255, 255, 255, 0.2); position: relative; flex-shrink: 0; }
    .modal-pay-radio.active { border-color: #2AABEE; }
    .modal-pay-radio.active::after { content: ''; position: absolute; top: 3px; left: 3px; width: 10px; height: 10px; border-radius: 50%; background: #2AABEE; }
    .modal-promo-section { margin-top: 0; }
    .modal-promo-row { display: flex; gap: 0.5rem; }
    .modal-promo-btn { background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 10px; padding: 0.7rem 1.2rem; color: rgba(255, 255, 255, 0.8); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.2s ease; white-space: nowrap; }
    .modal-promo-btn:hover { background: rgba(255, 255, 255, 0.15); }

    .modal-agreement {
        display: flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; color: rgba(255, 255, 255, 0.5); cursor: pointer; line-height: 1.4;
    }
    .modal-agreement input[type="checkbox"] { flex-shrink: 0; width: 16px; height: 16px; accent-color: #2AABEE; cursor: pointer; }
    .modal-agreement span { flex: 1; }
    .modal-agreement a { color: #2AABEE; text-decoration: none; }
    .modal-agreement a:hover { text-decoration: underline; }

    .modal-pay-button {
        width: 100%; padding: 0.9rem; background: linear-gradient(135deg, #2AABEE 0%, #229ED9 100%);
        border: none; border-radius: 12px; color: white; font-size: 1rem; font-weight: 700;
        cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
    }
    .modal-pay-button:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(42, 171, 238, 0.4); }

    .modal-error {
        display: flex; align-items: flex-start; gap: 0.5rem;
        padding: 0.65rem 0.9rem; margin: 0.35rem 0 0.5rem;
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 10px;
        color: #fca5a5; font-size: 0.85rem; line-height: 1.45;
    }
    .modal-error i { color: #ef4444; font-size: 1rem; flex-shrink: 0; margin-top: 1px; }

    .modal-guest-email-row { margin-top: 0.6rem; padding: 0.85rem 1rem; background: rgba(102,126,234,0.04); border: 1px solid rgba(102,126,234,0.2); border-radius: 12px; }
    .modal-guest-email-label { display: block; color: rgba(255,255,255,0.7); font-size: 0.82rem; margin-bottom: 0.4rem; font-weight: 500; }
</style>

<div class="container container-wide">
    <div class="d-flex gap-4">
        <!-- Left spacer for hero (same width as sidebar) -->
        <div class="game-sidebar-spacer"></div>
        <div class="tg-hero">
            <div class="tg-hero-badges">
                <span class="tg-hero-badge blue"><i class="bi bi-lightning-charge-fill"></i>Лучшие цены</span>
                <span class="tg-hero-badge green"><i class="bi bi-speedometer2"></i>Высокая скорость</span>
            </div>
            <h1 class="tg-hero-title">Telegram Premium</h1>
        </div>
    </div>

    <div class="game-page">
        <!-- Left spacer (same width as sidebar on other pages) -->
        <div class="game-sidebar-spacer"></div>

        <!-- Main Content -->
        <main class="game-main">
            <!-- Username input -->
            <div class="uid-section">
                <span class="uid-prefix">@@</span>
                <input type="text" class="uid-input" id="tgUsername" placeholder="Введите юзернейм Telegram получателя" autocomplete="off" spellcheck="false">
            </div>

            <!-- Telegram Premium Section -->
            @if (premiumProducts.Any())
            {
                <div class="product-section" style="margin-top: 0.5rem;">
                    <h2 class="section-title">Telegram Premium</h2>
                    <div class="currency-grid">
                        @foreach (var product in premiumProducts)
                        {
                            var hasImage = !string.IsNullOrEmpty(product.ImageUrl);
                            var displayName = !string.IsNullOrEmpty(product.TotalDisplay) ? product.TotalDisplay : product.Name;
                            var oldPrice = product.OldPrice ?? product.Price;
                            var gradient = premiumCard != null ? premiumCard.Gradient : "linear-gradient(135deg, #6C5CE7, #a855f7)";

                            <div class="product-item" onclick="selectPremium(this, @product.Id, '@product.Amount', '@displayName', @((int)product.Price), @((int)oldPrice))">
                                <div class="currency-card">
                                    <span class="currency-card-selected-badge">Выбрано <i class="bi bi-check"></i></span>
                                    <span class="currency-card-amount">@product.Amount</span>
                                    <div class="currency-card-image" style="background: @gradient;">
                                        @if (hasImage)
                                        {
                                            <img src="@product.ImageUrl" alt="@product.Name" />
                                        }
                                        else if (premiumCard != null && !string.IsNullOrEmpty(premiumCard.ImageUrl))
                                        {
                                            <img src="@premiumCard.ImageUrl" alt="@premiumCard.Name" />
                                        }
                                        else
                                        {
                                            <span class="currency-card-placeholder">💎</span>
                                        }
                                    </div>
                                </div>
                                <div class="product-caption">
                                    <div class="product-caption-price">
                                        @product.Price.ToString("N0") ₽
                                        @if (product.OldPrice.HasValue && product.OldPrice > product.Price)
                                        {
                                            <span class="product-caption-discount">-@product.Discount%</span>
                                            <span class="product-caption-old-price">@product.OldPrice.Value.ToString("N0") ₽</span>
                                        }
                                    </div>
                                    <div class="product-caption-name">@displayName</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (ViewBag.Reviews != null)
            {
                @await Html.PartialAsync("_ProductReviews", (DigiVault.Web.Models.ProductReviewsViewModel)ViewBag.Reviews)
            }
        </main>

        <!-- Payment Sidebar -->
        <aside class="payment-sidebar">
            <div class="payment-card">
                <div class="payment-product">
                    <div class="payment-product-icon" id="paymentIcon" style="background: linear-gradient(135deg, #2AABEE, #229ED9);">
                        <span>⭐</span>
                    </div>
                    <div class="payment-product-info">
                        <div class="payment-product-name" id="paymentName">Telegram</div>
                        <div class="payment-product-amount" id="selectedAmount">Выберите товар</div>
                    </div>
                </div>

                <div class="payment-summary">
                    <div class="payment-summary-row">
                        <span class="payment-summary-label">Цена</span>
                        <span class="payment-summary-value" id="originalPrice">0 ₽</span>
                    </div>
                    <div class="payment-summary-row">
                        <span class="payment-summary-label">Выгода</span>
                        <span class="payment-summary-value discount" id="discount">-0 ₽</span>
                    </div>
                    <div class="payment-summary-total">
                        <span class="payment-total-label">Итого</span>
                        <span class="payment-total-value" id="totalPrice">0 ₽</span>
                    </div>
                </div>

                <button class="payment-button" onclick="openPurchaseModal()">
                    Купить <span id="buttonPrice">0</span> ₽
                </button>

                <div class="payment-delivery">
                    <div class="payment-delivery-row">
                        <span class="payment-delivery-label">Доставка</span>
                        <span class="payment-delivery-value highlight">В Telegram</span>
                    </div>
                    <div class="payment-delivery-row">
                        <span class="payment-delivery-label">Срок доставки</span>
                        <span class="payment-delivery-value">До 30 минут</span>
                    </div>
                </div>
            </div>

            <!-- Trust Badge -->
            <div class="trust-badge">
                <div class="trust-badge-item">
                    <i class="bi bi-shield-check trust-badge-icon" style="color: #2AABEE;"></i>
                    <span class="trust-badge-text">Безопасная<br>покупка</span>
                </div>
                <div class="trust-badge-divider"></div>
                <div class="trust-badge-item">
                    <i class="bi bi-bag-check trust-badge-icon" style="color: #f093fb;"></i>
                    <span class="trust-badge-text">100K+<br>продаж</span>
                </div>
            </div>
        </aside>
    </div>

    <!-- FAQ Section -->
    <div class="d-flex" style="gap: 1.5rem;">
        <div class="game-sidebar-spacer"></div>
        <div class="faq-section flex-grow-1" style="min-width: 0;">
            <h2 class="faq-title">Ответы на вопросы</h2>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">
                    <span>Как активируется Telegram Premium?</span>
                    <i class="bi bi-plus-lg"></i>
                </div>
                <div class="faq-answer">
                    <div class="faq-answer-inner">После оплаты подписка активируется на указанный юзернейм автоматически в течение 1-3 минут. В Telegram у получателя появится значок Premium и доступ ко всем плюшкам.</div>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">
                    <span>Где найти свой юзернейм Telegram?</span>
                    <i class="bi bi-plus-lg"></i>
                </div>
                <div class="faq-answer">
                    <div class="faq-answer-inner">Откройте Telegram → Настройки (три полоски слева сверху). Ваш юзернейм отображается под именем профиля в формате @@username. На телефоне нажмите и удерживайте поле — юзернейм скопируется автоматически.</div>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">
                    <span>Как создать юзернейм, если его нет?</span>
                    <i class="bi bi-plus-lg"></i>
                </div>
                <div class="faq-answer">
                    <div class="faq-answer-inner">Перейдите в Настройки Telegram → нажмите на поле «Имя пользователя» → придумайте уникальное имя и сохраните. Без юзернейма получить Premium не получится — он нужен как идентификатор аккаунта.</div>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">
                    <span>Это безопасно?</span>
                    <i class="bi bi-plus-lg"></i>
                </div>
                <div class="faq-answer">
                    <div class="faq-answer-inner">Абсолютно. Активация Premium происходит через официальные инструменты Telegram. Мы не запрашиваем пароль, код подтверждения или доступ к аккаунту — только публичный юзернейм.</div>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">
                    <span>Можно подарить Premium другому человеку?</span>
                    <i class="bi bi-plus-lg"></i>
                </div>
                <div class="faq-answer">
                    <div class="faq-answer-inner">Да, просто введите юзернейм получателя при оформлении. Подарок придёт ему напрямую — никаких сообщений или промокодов отправлять не нужно.</div>
                </div>
            </div>

            <div class="faq-item">
                <div class="faq-question" onclick="toggleFaq(this)">
                    <span>Что входит в Telegram Premium?</span>
                    <i class="bi bi-plus-lg"></i>
                </div>
                <div class="faq-answer">
                    <div class="faq-answer-inner">Удвоенные лимиты на чаты, папки и закреплённые сообщения, загрузка файлов до 4 ГБ, ускоренная скачка, эксклюзивные стикеры и реакции, голосовые сообщения в текст, закрытый бейдж в профиле, без рекламы в публичных каналах.</div>
                </div>
            </div>
        </div>
        <div class="payment-sidebar-spacer"></div>
    </div>
</div>

@Html.AntiForgeryToken()

<!-- Purchase Modal -->
<div class="purchase-overlay" id="purchaseOverlay" onclick="if(event.target===this)closePurchaseModal()">
    <div class="purchase-modal">
        <div class="purchase-modal-header">
            <h3>Купить товар</h3>
            <button class="purchase-modal-close" onclick="closePurchaseModal()">&times;</button>
        </div>
        <div class="purchase-modal-body" id="paymentStep1">
            <div class="purchase-modal-left">
                <div class="purchase-modal-image" id="modalImage" style="background: linear-gradient(135deg, #2AABEE, #229ED9);">
                    <span class="modal-placeholder">⭐</span>
                </div>
                <div class="purchase-modal-product-name" id="modalProductName">Telegram</div>
                <div class="purchase-modal-product-desc" id="modalProductDesc">Выберите товар</div>
                <div class="purchase-modal-price-row">
                    Цена: <span style="color: #2AABEE;" id="modalPrice">0 ₽</span>
                    <span class="old-price" id="modalOldPrice" style="display:none;">0 ₽</span>
                </div>
            </div>
            <div class="purchase-modal-right">
                <div>
                    <div class="modal-label">Юзернейм Telegram:</div>
                    <input type="text" class="modal-input" id="modalInput" placeholder="@@username" />
                    <div class="modal-hint">Звёзды / Премиум будут доставлены на этот аккаунт</div>
                </div>

                @if (User.Identity?.IsAuthenticated != true)
                {
                    <div class="modal-info-banner">
                        <i class="bi bi-info-circle" style="color: #667eea; margin-right: 0.3rem;"></i>
                        Покупка без регистрации возможна. <a href="/Account/Register">Создать аккаунт</a> чтобы сохранять историю и пользоваться балансом.
                    </div>
                    
                }

                <div>
                    <div class="modal-label">Способ оплаты:</div>
                    @{
                        var __tgAuth = User.Identity?.IsAuthenticated == true;
                        var __tgBal  = ViewBag.UserBalance is decimal __tb ? __tb : 0m;
                        var __tgTiles = new DigiVault.Web.Models.Payment.PaymentTilesViewModel
                        {
                            ShowBalance  = __tgAuth,
                            Balance      = __tgBal,
                            SelectedCode = __tgAuth ? "balance" : "card",
                            OnSelectJs   = "selectModalPayment"
                        };
                    }
                    <partial name="_PaymentMethodTiles" model="__tgTiles" />
                </div>

                <div class="modal-promo-section">
                    <div class="modal-label">Промокод (необязательно)</div>
                    <div class="modal-promo-row">
                        <input type="text" class="modal-input" id="promoInput" placeholder="Введите промокод" style="flex: 1;" />
                        <button class="modal-promo-btn" onclick="alert('Промокоды скоро будут доступны!')">Применить</button>
                    </div>
                </div>

                <label class="modal-agreement">
                    <input type="checkbox" id="modalAgree" checked />
                    <span>Я согласен с <a href="/Terms">условиями использования</a> и <a href="/Privacy">политикой конфиденциальности</a></span>
                </label>

<div id="modalError" class="modal-error" style="display:none;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span id="modalErrorText"></span>
                </div>
                                <button class="modal-pay-button" onclick="processPurchase()">
                    <i class="bi bi-cart-check"></i> Оплатить
                </button>
            </div>
        </div>
        <div class="purchase-modal-body" id="paymentStep2Wrapper" style="display:none;">
            <div style="width:100%;">
                @await Html.PartialAsync("_PaymentMethodPicker")
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    // FAQ toggle
    function toggleFaq(el) {
        const item = el.parentElement;
        const wasOpen = item.classList.contains('open');
        // Close all
        document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
        // Toggle clicked
        if (!wasOpen) item.classList.add('open');
    }


    let selectedPrice = 0;
    let selectedOldPrice = 0;
    let selectedAmount = '';
    let selectedImageUrl = '';
    let selectedProductId = 0;
    let selectionMode = 'premium';

    function resetSidebar() {
        selectedPrice = 0;
        selectedOldPrice = 0;
        selectedAmount = '';
        selectedProductId = 0;
        document.getElementById('paymentIcon').style.background = 'linear-gradient(135deg, #6C5CE7, #a855f7)';
        document.getElementById('paymentIcon').innerHTML = '<span>\uD83D\uDC8E</span>';
        document.getElementById('paymentName').textContent = 'Telegram Premium';
        document.getElementById('selectedAmount').textContent = '\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0442\u0430\u0440\u0438\u0444';
        document.getElementById('originalPrice').textContent = '0 \u20BD';
        document.getElementById('discount').textContent = '-0 \u20BD';
        document.getElementById('totalPrice').textContent = '0 \u20BD';
        document.getElementById('buttonPrice').textContent = '0';
    }

    // --- Premium selection ---
    function selectPremium(item, productId, amount, displayName, price, oldPrice) {
        // Select card
        document.querySelectorAll('.product-item').forEach(c => c.classList.remove('selected'));
        item.classList.add('selected');

        const cardImg = item.querySelector('.currency-card-image img');
        selectedImageUrl = cardImg ? cardImg.src : '';

        selectionMode = 'premium';
        selectedProductId = productId;
        selectedPrice = price;
        selectedOldPrice = oldPrice;
        selectedAmount = displayName;

        const discount = oldPrice - price;
        const discountPercent = oldPrice > 0 ? Math.round((discount / oldPrice) * 100) : 0;

        // Update sidebar
        document.getElementById('paymentIcon').style.background = '@(premiumCard?.Gradient ?? "linear-gradient(135deg, #6C5CE7, #a855f7)")';
        if (selectedImageUrl) {
            document.getElementById('paymentIcon').innerHTML = '<img src="' + selectedImageUrl + '" alt="Premium" />';
        } else {
            document.getElementById('paymentIcon').innerHTML = '<span>\uD83D\uDC8E</span>';
        }
        document.getElementById('paymentName').textContent = 'Telegram Premium';
        document.getElementById('selectedAmount').textContent = displayName;
        document.getElementById('originalPrice').textContent = oldPrice.toLocaleString('ru-RU') + ' \u20BD';

        if (discount > 0) {
            document.getElementById('discount').innerHTML = '-' + discount.toLocaleString('ru-RU') + ' \u20BD <span style="background: #22c55e; color: white; padding: 0.1rem 0.3rem; border-radius: 3px; font-size: 0.7rem;">-' + discountPercent + '%</span>';
        } else {
            document.getElementById('discount').textContent = '-0 \u20BD';
        }

        document.getElementById('totalPrice').textContent = price.toLocaleString('ru-RU') + ' \u20BD';
        document.getElementById('buttonPrice').textContent = price.toLocaleString('ru-RU');
    }

    // --- Purchase Modal ---
    function openPurchaseModal() {
        if (selectedPrice <= 0) {
            showModalError('\u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430, \u0432\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0442\u043E\u0432\u0430\u0440');
            return;
        }

        // Pre-fill username from page input
        const tgUser = document.getElementById('tgUsername');
        if (tgUser && tgUser.value.trim()) {
            document.getElementById('modalInput').value = '@@' + tgUser.value.trim().replace(/^@@/, '');
        }

        document.getElementById('modalProductName').textContent = 'Telegram Premium';
        document.getElementById('modalImage').style.background = '@(premiumCard?.Gradient ?? "linear-gradient(135deg, #6C5CE7, #a855f7)")';
        if (selectedImageUrl) {
            document.getElementById('modalImage').innerHTML = '<img src="' + selectedImageUrl + '" alt="Premium" />';
        } else {
            document.getElementById('modalImage').innerHTML = '<span class="modal-placeholder">\uD83D\uDC8E</span>';
        }

        document.getElementById('modalProductDesc').textContent = selectedAmount;
        document.getElementById('modalPrice').textContent = selectedPrice.toLocaleString('ru-RU') + ' \u20BD';
        if (selectedOldPrice > selectedPrice) {
            document.getElementById('modalOldPrice').textContent = selectedOldPrice.toLocaleString('ru-RU') + ' \u20BD';
            document.getElementById('modalOldPrice').style.display = '';
        } else {
            document.getElementById('modalOldPrice').style.display = 'none';
        }

        document.getElementById('purchaseOverlay').classList.add('active');
        document.body.style.overflow = 'hidden';
    }

    function closePurchaseModal() {
        document.getElementById('purchaseOverlay').classList.remove('active');
        document.body.style.overflow = '';
    }

    function selectModalPayment(el) {
        if (el.classList.contains('disabled')) return;
        document.querySelectorAll('.modal-pay-method').forEach(c => {
            c.classList.remove('selected');
            const radio = c.querySelector('.modal-pay-radio');
            if (radio) radio.classList.remove('active');
        });
        el.classList.add('selected');
        const radio = el.querySelector('.modal-pay-radio');
        if (radio) radio.classList.add('active');
    }


    // Inline form errors (replaces native showModalError() popups inside the modal).
    function showModalError(msg) {
        const el = document.getElementById('modalError');
        const tx = document.getElementById('modalErrorText');
        if (!el || !tx) { console.warn('modalError missing'); return; }
        tx.textContent = msg;
        el.style.display = 'flex';
        try { el.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); } catch {}
    }
    function clearModalError() {
        const el = document.getElementById('modalError');
        if (el) el.style.display = 'none';
    }

    function processPurchase() {
        clearModalError();
        const input = document.getElementById('modalInput');
        const val = input.value.trim();
        const agree = document.getElementById('modalAgree');

        if (!val) { showModalError('\u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430, \u0432\u0432\u0435\u0434\u0438\u0442\u0435 \u044E\u0437\u0435\u0440\u043D\u0435\u0439\u043C Telegram'); input.focus(); return; }
        if (!agree.checked) { showModalError('\u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430, \u043F\u0440\u0438\u043C\u0438\u0442\u0435 \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E \u0441\u043E\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u044F'); return; }

        if (!selectedProductId) {
            showModalError('\u041F\u043E\u0436\u0430\u043B\u0443\u0439\u0441\u0442\u0430, \u0432\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0442\u043E\u0432\u0430\u0440');
            return;
        }

        @if (!User.Identity?.IsAuthenticated ?? true)
        {
            <text>
            // Guest checkout: use the existing delivery-email input if it's an
            // email (gift cards, VPN, streaming services). For UID/username-
            // delivery products there's no email to bind to, so we send the
            // user to login.
            const _delivInp = document.getElementById('modalInput');
            const _delivVal = _delivInp ? _delivInp.value.trim() : '';
            const _isEmail  = /^[^@@\s]+@@[^@@\s]+\.[^@@\s]+$/.test(_delivVal);
            if (_isEmail) {
                window.guestCheckoutEmail = _delivVal;
            } else {
                window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                return;
            }
            </text>
        }
        else
        {
            <text>window.guestCheckoutEmail = null;</text>
        }

        const btn = document.querySelector('.modal-pay-button');
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-hourglass-split"></i> \u041E\u0431\u0440\u0430\u0431\u043E\u0442\u043A\u0430...';

        const selectedMethod = document.querySelector('.modal-pay-method.selected')?.dataset.method || 'balance';
        if (selectedMethod !== 'balance') {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-cart-check"></i> \u041E\u043F\u043B\u0430\u0442\u0438\u0442\u044C';
            window.lastSelectedPrice = selectedPrice;
            window.openPaymentStep2(selectedMethod);
            return;
        }
        submitPurchaseFetchTg({ method: 'balance', service: null, deliveryInfo: val, btn: btn });
    }

    function submitPurchaseFetchTg({ method, service, deliveryInfo, btn }) {
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const body = JSON.stringify({
            gameProductId: selectedProductId,
            deliveryInfo: deliveryInfo,
            paymentMethod: method,
            enotService: service,
            email: window.guestCheckoutEmail || null,
        });
        fetch('/Catalog/Purchase', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            body: body
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                if (data.redirectUrl) { window.location.href = data.redirectUrl; return; }
                window.location.href = "/Account/OrderDetails?orderNumber=" + encodeURIComponent(data.orderNumber); return;
            } else {
                showModalError(data.errorMessage || '\u041E\u0448\u0438\u0431\u043A\u0430 \u043F\u0440\u0438 \u043F\u043E\u043A\u0443\u043F\u043A\u0435');
                if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-cart-check"></i> \u041E\u043F\u043B\u0430\u0442\u0438\u0442\u044C'; }
            }
        })
        .catch(() => {
            showModalError('\u041E\u0448\u0438\u0431\u043A\u0430 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F');
            if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-cart-check"></i> \u041E\u043F\u043B\u0430\u0442\u0438\u0442\u044C'; }
        });
    }

    window.submitPurchaseWithService = function (method, serviceCode, tile) {
        const input = document.getElementById('modalInput');
        const val = input ? input.value.trim() : '';
        submitPurchaseFetchTg({ method: method, service: serviceCode, deliveryInfo: val, btn: null });
    };

    function showPurchaseSuccess(orderNumber, productKey, newBalance) {
        const modal = document.querySelector('.purchase-modal-body');
        const balanceHtml = newBalance !== null ? `<div style="color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 0.75rem;">\u041E\u0441\u0442\u0430\u0442\u043E\u043A \u043D\u0430 \u0431\u0430\u043B\u0430\u043D\u0441\u0435: <span style="color: #22c55e; font-weight: 600;">${Math.floor(newBalance).toLocaleString('ru-RU')} \u20BD</span></div>` : '';
        modal.innerHTML = `
            <div style="text-align: center; padding: 2.5rem 2rem; width: 100%; max-width: 480px; margin: 0 auto;">
                <div style="width: 80px; height: 80px; background: linear-gradient(135deg, #2AABEE, #229ED9); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
