    .policy-title .gradient-text { background: linear-gradient(135deg, #667eea 0%, #f093fb 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    .policy-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 2.5rem;
        color: rgba(255,255,255,0.75);
        line-height: 1.7;
    }

    .policy-card .section { margin-bottom: 2rem; }
    .policy-card .section:last-child { margin-bottom: 0; }
    .policy-card h5 { color: #667eea; font-weight: 700; margin-bottom: 1rem; }
    .policy-card p { margin-bottom: 0.85rem; }
    .policy-card a { color: #667eea; text-decoration: none; }
    .policy-card a:hover { text-decoration: underline; }

    @@media (max-width: 768px) {
        .policy-card { padding: 1.5rem; }
