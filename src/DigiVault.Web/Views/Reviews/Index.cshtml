@using DigiVault.Core.Entities
@using DigiVault.Core.Enums
@using DigiVault.Web.Controllers
@model List<ProductReview>
@{
    ViewData["Title"] = "Отзывы клиентов";
    var stats = (ReviewStats)ViewBag.Stats;
    var category = (string?)ViewBag.Category;
    var rating = (int?)ViewBag.Rating;
    var sort = (string)ViewBag.Sort;
    var product = (string?)ViewBag.Product;
    var page = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var totalFiltered = (int)ViewBag.TotalFiltered;
    var isAuthenticated = (bool)ViewBag.IsAuthenticated;
    var hasPurchase = (bool)ViewBag.HasPurchase;

    string CategoryTagFor(ProductReview r)
    {
        if (r.Game != null) return r.Game.Name;
        if (r.GiftCard != null) return r.GiftCard.Name;
        if (r.VpnProvider != null) return r.VpnProvider.Name;
        return "";
    }

    string InitialsOf(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var parts = name.Split(new[] { ' ', '_', '.', '-' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) return (parts[0][0].ToString() + parts[1][0].ToString()).ToUpperInvariant();
        return name.Length >= 2 ? name.Substring(0, 2).ToUpperInvariant() : name.ToUpperInvariant();
    }

    // Deterministic avatar color based on name hash
    string AvatarColorFor(string name)
    {
        var colors = new[] {
            "linear-gradient(135deg, #667eea, #764ba2)",
            "linear-gradient(135deg, #f093fb, #f5576c)",
            "linear-gradient(135deg, #4facfe, #00f2fe)",
            "linear-gradient(135deg, #43e97b, #38f9d7)",
            "linear-gradient(135deg, #fa709a, #fee140)",
            "linear-gradient(135deg, #a18cd1, #fbc2eb)",
            "linear-gradient(135deg, #30cfd0, #330867)",
            "linear-gradient(135deg, #ff9a9e, #fad0c4)",
        };
        unchecked
        {
            int hash = 0;
            foreach (var c in name) hash = hash * 31 + c;
            return colors[Math.Abs(hash) % colors.Length];
        }
    }

    string FormatDate(DateTime date)
    {
        var months = new[] { "января", "февраля", "марта", "апреля", "мая", "июня",
                             "июля", "августа", "сентября", "октября", "ноября", "декабря" };
        return $"{date.Day} {months[date.Month - 1]} {date.Year} г.";
    }
}

<section class="reviews-hero">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="reviews-title">
                <span class="gradient-text">Отзывы клиентов</span>
            </h1>
            <p class="reviews-subtitle">
                Узнайте, что говорят о нас более @stats.TotalCount довольных покупателей
            </p>
        </div>

        <!-- Stats Block -->
        <div class="reviews-stats-card mb-4">
            <div class="row g-4 py-4 px-3 px-md-5">
                <div class="col-md-3 col-6 text-center">
                    <div class="rstat-value" style="color:#667eea;">@stats.AverageRating.ToString("F1")</div>
                    <div class="rstat-stars mb-2">
                        @for (int s = 1; s <= 5; s++)
                        {
                            var filled = s <= Math.Round(stats.AverageRating);
                            <i class="bi @(filled ? "bi-star-fill" : "bi-star")" style="color:@(filled ? "#fbbf24" : "rgba(255,255,255,0.15)");"></i>
                        }
                    </div>
                    <div class="rstat-label">Средний рейтинг</div>
                    <div class="rstat-sublabel">из @stats.TotalCount отзывов</div>
                </div>
                <div class="col-md-3 col-6 text-center">
                    <div class="rstat-value" style="color:#22c55e;">@stats.RecommendPercent.ToString("F1")%</div>
                    <div class="rstat-label mt-2">Уровень удовлетворённости</div>
                    <div class="rstat-sublabel">рекомендуют нас</div>
                </div>
                <div class="col-md-3 col-6 text-center">
                    <div class="rstat-value" style="color:#f093fb;">@stats.TotalCount</div>
                    <div class="rstat-label mt-2">Всего отзывов</div>
                    <div class="rstat-sublabel">за последний год</div>
                </div>
                <div class="col-md-3 col-6 text-center">
                    <div class="rstat-value" style="color:#4facfe;">24ч</div>
                    <div class="rstat-label mt-2">Время ответа</div>
                    <div class="rstat-sublabel">на каждый отзыв</div>
                </div>
            </div>

            <hr class="m-0" style="border-color: var(--card-border);">

            <div class="p-3 p-md-5">
                <h6 class="mb-3" style="color:rgba(255,255,255,0.7); font-weight:600;">Распределение оценок</h6>
                @for (int r = 5; r >= 1; r--)
                {
                    var count = stats.GetCount(r);
                    var pct = stats.GetPercent(r);
                    <div class="rating-row">
                        <div class="rating-label">
                            <span>@r</span>
                            <i class="bi bi-star-fill" style="color:#fbbf24; font-size:0.85rem;"></i>
                        </div>
                        <div class="rating-bar-wrap">
                            <div class="rating-bar" style="width:@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                        </div>
                        <div class="rating-count">@count (@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%)</div>
                    </div>
                }
            </div>
        </div>

        <!-- Filters + Write Review -->
        <div class="reviews-filters-card mb-4">
            <form method="get" class="d-flex align-items-center gap-2 flex-wrap w-100" id="filterForm">
                @if (!string.IsNullOrEmpty(product))
                {
                    <input type="hidden" name="product" value="@product" />
                }
                <select name="category" class="form-select reviews-select" onchange="document.getElementById('filterForm').submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(category))">Все услуги</option>
                    <option value="games" selected="@(category == "games")">Игровая валюта</option>
                    <option value="telegram" selected="@(category == "telegram")">Telegram</option>
                    <option value="giftcards" selected="@(category == "giftcards")">Подарочные карты</option>
                    <option value="vpn" selected="@(category == "vpn")">VPN</option>
                </select>

                <div class="rating-filter">
                    @for (int s = 5; s >= 1; s--)
                    {
                        var active = rating == s;
                        <a href="?category=@category&rating=@(active ? "" : s.ToString())&sort=@sort&product=@product"
                           class="rating-star-btn @(active ? "active" : "")" title="@s звёзд">
                            <i class="bi bi-star-fill"></i>
                        </a>
                    }
                    @if (rating.HasValue)
                    {
                        <a href="?category=@category&sort=@sort&product=@product" class="rating-clear">сбросить</a>
                    }
                </div>

                <select name="sort" class="form-select reviews-select" onchange="document.getElementById('filterForm').submit()">
                    <option value="newest" selected="@(sort == "newest")">Сначала новые</option>
                    <option value="oldest" selected="@(sort == "oldest")">Сначала старые</option>
                    <option value="helpful" selected="@(sort == "helpful")">По полезности</option>
                    <option value="rating_high" selected="@(sort == "rating_high")">Высокие оценки</option>
                    <option value="rating_low" selected="@(sort == "rating_low")">Низкие оценки</option>
                </select>

                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="text-muted small d-none d-md-inline">Показано: @totalFiltered</span>
                    @if (!isAuthenticated)
                    {
                        <a href="/Account/Login" class="btn btn-primary btn-write-review" data-bs-toggle="tooltip" title="Войдите, чтобы оставить отзыв">
                            <i class="bi bi-pencil-square me-1"></i>Написать отзыв
                        </a>
                    }
                    else if (!hasPurchase)
                    {
                        <button type="button" class="btn btn-primary btn-write-review" disabled
                                data-bs-toggle="tooltip" title="Оставить отзыв можно только после покупки">
                            <i class="bi bi-pencil-square me-1"></i>Написать отзыв
                        </button>
                    }
                    else
                    {
                        <a href="/Catalog" class="btn btn-primary btn-write-review" data-bs-toggle="tooltip"
                           title="Перейдите на страницу купленного товара чтобы оставить отзыв">
                            <i class="bi bi-pencil-square me-1"></i>Написать отзыв
                        </a>
                    }
                </div>
            </form>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success mb-3">
                <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            </div>
        }

        <!-- Review cards -->
        @if (!Model.Any())
        {
            <div class="review-card p-5 text-center">
                <i class="bi bi-chat-square-text" style="font-size:3rem; color:rgba(255,255,255,0.2);"></i>
                <h5 class="mt-3 text-muted">По вашему фильтру отзывов пока нет</h5>
                <p class="text-muted small">Попробуйте изменить фильтры или сбросить их</p>
            </div>
        }
        else
        {
            foreach (var r in Model)
            {
                <article class="review-card mb-3">
                    <div class="d-flex align-items-start gap-3 mb-3 flex-wrap">
                        <div class="review-avatar" style="background: @AvatarColorFor(r.AuthorName);">
                            @InitialsOf(r.AuthorName)
                        </div>
                        <div class="flex-grow-1" style="min-width:0;">
                            <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                                <div>
                                    <div class="review-author">@r.AuthorName</div>
                                    @if (!string.IsNullOrEmpty(r.AuthorRole))
                                    {
                                        <div class="review-role">@r.AuthorRole</div>
                                    }
                                    <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                                        <div class="review-stars">
                                            @for (int s = 1; s <= 5; s++)
                                            {
                                                <i class="bi @(s <= r.Rating ? "bi-star-fill" : "bi-star")" style="color:@(s <= r.Rating ? "#fbbf24" : "rgba(255,255,255,0.15)");"></i>
                                            }
                                        </div>
                                        <span class="review-date">@FormatDate(r.CreatedAt)</span>
                                        @if (r.IsVerifiedPurchase)
                                        {
                                            <span class="review-verified">
                                                <i class="bi bi-patch-check-fill"></i> Проверенный отзыв
                                            </span>
                                        }
                                    </div>
                                </div>
                                @{
                                    var tagText = CategoryTagFor(r);
                                    var linkCategory = r.Game != null ? "Game" : r.GiftCard != null ? "GiftCard" : "VpnProvider";
                                    var linkSlug = r.Game?.Slug ?? r.GiftCard?.Slug ?? r.VpnProvider?.Slug ?? "";
                                }
                                @if (!string.IsNullOrEmpty(tagText))
                                {
                                    <a href="/Catalog/@linkCategory/@linkSlug" class="review-tag">@tagText</a>
                                }
                            </div>
                        </div>
                    </div>

                    <h6 class="review-title mb-2">@r.Title</h6>
                    <p class="review-text mb-3">@r.Text</p>

                    @if (!string.IsNullOrEmpty(r.AdminReply))
                    {
                        <div class="review-reply">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div class="review-reply-avatar">
                                    <i class="bi bi-shield-lock-fill"></i>
                                </div>
                                <div>
                                    <div class="review-reply-author">Команда Key Zona</div>
                                    @if (r.AdminReplyAt.HasValue)
                                    {
                                        <div class="review-reply-date">@FormatDate(r.AdminReplyAt.Value)</div>
                                    }
                                </div>
                            </div>
                            <div class="review-reply-text">@r.AdminReply</div>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3" style="border-top: 1px solid var(--card-border);">
                        <button type="button" class="btn-helpful" data-review-id="@r.Id">
                            <i class="bi bi-hand-thumbs-up"></i>
                            Полезный отзыв (<span class="helpful-count">@r.HelpfulCount</span>)
                        </button>
                        <div>
                            <button type="button" class="btn-icon-ghost" title="Поделиться">
                                <i class="bi bi-share"></i>
                            </button>
                        </div>
                    </div>
                </article>
            }
        }

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-center mt-4 mb-5">
                <nav>
                    <ul class="pagination pagination-reviews">
                        @if (page > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="?category=@category&rating=@rating&sort=@sort&product=@product&page=@(page - 1)">
                                    <i class="bi bi-arrow-left"></i>
                                </a>
                            </li>
                        }
                        @{
                            int fromP = Math.Max(1, page - 3);
                            int toP = Math.Min(totalPages, page + 3);
                        }
                        @for (int p = fromP; p <= toP; p++)
                        {
                            <li class="page-item @(p == page ? "active" : "")">
                                <a class="page-link" href="?category=@category&rating=@rating&sort=@sort&product=@product&page=@p">@p</a>
                            </li>
                        }
                        @if (page < totalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="?category=@category&rating=@rating&sort=@sort&product=@product&page=@(page + 1)">
                                    <i class="bi bi-arrow-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
</section>

@section Styles {
<style>
    .reviews-hero { padding: 60px 0 80px; }
    .reviews-title { font-size: 3rem; font-weight: 800; margin-bottom: 1rem; }
    .reviews-title .gradient-text { background: linear-gradient(135deg, #667eea 0%, #f093fb 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .reviews-subtitle { font-size: 1.1rem; color: rgba(255,255,255,0.55); }

    .reviews-stats-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 20px; overflow: hidden; }
    .rstat-value { font-size: 2.75rem; font-weight: 800; line-height: 1; }
    .rstat-stars i { font-size: 0.95rem; }
    .rstat-label { color: rgba(255,255,255,0.7); font-size: 0.9rem; font-weight: 500; }
    .rstat-sublabel { color: rgba(255,255,255,0.35); font-size: 0.8rem; margin-top: 2px; }

    .rating-row { display: flex; align-items: center; gap: 14px; margin-bottom: 8px; }
    .rating-row:last-child { margin-bottom: 0; }
    .rating-label { display: flex; align-items: center; gap: 4px; min-width: 32px; color: rgba(255,255,255,0.7); font-weight: 600; font-size: 0.9rem; }
    .rating-bar-wrap { flex: 1; height: 8px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; }
    .rating-bar { height: 100%; background: linear-gradient(90deg, #667eea, #f093fb); border-radius: 4px; transition: width 0.5s ease; }
    .rating-count { min-width: 110px; text-align: right; color: rgba(255,255,255,0.45); font-size: 0.85rem; }

    .reviews-filters-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 1rem 1.25rem; }
    .reviews-select { background: rgba(255,255,255,0.04); border: 1px solid var(--card-border); color: #fff; border-radius: 10px; width: auto; min-width: 160px; }
    .reviews-select:focus { background: rgba(255,255,255,0.06); border-color: rgba(102,126,234,0.5); box-shadow: 0 0 0 3px rgba(102,126,234,0.1); color:#fff; }
    .reviews-select option { background: #1a1a23; color: #fff; }

    .rating-filter { display: flex; align-items: center; gap: 2px; padding: 0.3rem 0.5rem; background: rgba(255,255,255,0.04); border: 1px solid var(--card-border); border-radius: 10px; }
    .rating-star-btn { color: rgba(255,255,255,0.15); padding: 4px 5px; font-size: 0.95rem; text-decoration: none; transition: color 0.2s; }
    .rating-star-btn:hover { color: #fbbf24; }
    .rating-star-btn.active { color: #fbbf24; }
    .rating-clear { font-size: 11px; color: rgba(255,255,255,0.4); text-decoration: none; margin-left: 6px; }
    .rating-clear:hover { color: #fff; }

    .btn-write-review { padding: 0.6rem 1.4rem; font-weight: 600; border-radius: 10px; }

    .review-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 1.5rem; transition: border-color 0.2s; }
    .review-card:hover { border-color: rgba(102,126,234,0.25); }

    .review-avatar { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700; font-size: 1rem; flex-shrink: 0; }
    .review-author { font-weight: 700; color: #fff; font-size: 1.05rem; }
    .review-role { color: rgba(255,255,255,0.45); font-size: 0.85rem; margin-top: 2px; }
    .review-stars i { font-size: 0.85rem; }
    .review-date { color: rgba(255,255,255,0.45); font-size: 0.85rem; }
    .review-verified { color: #22c55e; font-size: 0.8rem; font-weight: 500; display: inline-flex; align-items: center; gap: 4px; }
    .review-tag { display: inline-block; padding: 5px 12px; background: rgba(102,126,234,0.15); color: #a5b4fc; border-radius: 8px; font-size: 0.8rem; font-weight: 600; text-decoration: none; transition: background 0.2s; border: 1px solid rgba(102,126,234,0.2); }
    .review-tag:hover { background: rgba(102,126,234,0.25); color: #c7d2fe; }

    .review-title { color: #fff; font-weight: 700; font-size: 1.1rem; }
    .review-text { color: rgba(255,255,255,0.7); line-height: 1.6; font-size: 0.95rem; white-space: pre-wrap; }

    .review-reply { background: rgba(255,255,255,0.03); border-left: 3px solid #667eea; border-radius: 8px; padding: 1rem 1.25rem; margin-top: 0.75rem; }
    .review-reply-avatar { width: 32px; height: 32px; border-radius: 9px; background: var(--primary-gradient); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.85rem; flex-shrink: 0; }
    .review-reply-author { font-weight: 700; color: #fff; font-size: 0.9rem; }
    .review-reply-date { color: rgba(255,255,255,0.4); font-size: 0.75rem; }
    .review-reply-text { color: rgba(255,255,255,0.65); font-size: 0.9rem; line-height: 1.55; }

    .btn-helpful { background: transparent; border: none; color: rgba(255,255,255,0.5); font-size: 0.85rem; padding: 4px 0; transition: color 0.2s; display: inline-flex; align-items: center; gap: 6px; }
    .btn-helpful:hover { color: #667eea; }
    .btn-helpful.voted { color: #22c55e; }
    .btn-icon-ghost { background: transparent; border: none; color: rgba(255,255,255,0.35); padding: 4px 8px; }
    .btn-icon-ghost:hover { color: rgba(255,255,255,0.65); }

    .pagination-reviews .page-link {
        background: var(--card-bg); border: 1px solid var(--card-border); color: rgba(255,255,255,0.7);
        margin: 0 4px; border-radius: 10px; padding: 0.5rem 1rem;
    }
    .pagination-reviews .page-link:hover { background: var(--card-hover); color: #fff; }
    .pagination-reviews .page-item.active .page-link {
        background: var(--primary-gradient); border-color: transparent; color: #fff;
    }

    @@media (max-width: 768px) {
        .reviews-title { font-size: 2rem; }
        .reviews-subtitle { font-size: 0.95rem; }
        .rstat-value { font-size: 2rem; }
        .btn-write-review { width: 100%; }
        .reviews-select { width: 100%; flex: 1; }
    }
</style>
}

@section Scripts {
<script>
    // Mark helpful — AJAX POST
    document.querySelectorAll('.btn-helpful').forEach(btn => {
        btn.addEventListener('click', async () => {
            if (btn.classList.contains('voted')) return;
            const id = btn.dataset.reviewId;
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            try {
                const fd = new FormData();
                fd.append('id', id);
                if (token) fd.append('__RequestVerificationToken', token);
                const res = await fetch('/Reviews/MarkHelpful', { method: 'POST', body: fd });
                if (res.ok) {
                    const data = await res.json();
                    btn.querySelector('.helpful-count').textContent = data.count;
                    btn.classList.add('voted');
                }
            } catch { /* silent */ }
        });
    });

    // Tooltips
    if (window.bootstrap) {
        [...document.querySelectorAll('[data-bs-toggle="tooltip"]')].forEach(el => new bootstrap.Tooltip(el));
    }
</script>
<form style="display:none;">@Html.AntiForgeryToken()</form>
}
