@*
    Step-2 payment system picker for the purchase modal.

    Render this partial inside the modal body (sibling of #paymentStep1).
    JS contract:
      - call `window.openPaymentStep2(method)` to switch from step 1 to this view
      - back button calls `window.closePaymentStep2()`
      - clicking a tile selects it; clicking the bottom "Оплатить" calls
        `window.submitPurchaseWithService(method, serviceCode, tile)` which
        the host page (Game/GiftCard/VpnProvider/Telegram) defines.
*@

<div id="paymentStep2" class="ps2" style="display:none;">
    <div class="ps2-top">
        <button type="button" class="ps2-back" onclick="closePaymentStep2()">
            <i class="bi bi-arrow-left"></i>
        </button>
        <div class="ps2-top-text">
            <div class="ps2-eyebrow">
                Способ оплаты: <span class="ps2-method-name" id="paymentStep2MethodLabel">—</span>
            </div>
            <h4 class="ps2-title">Выберите платёжную систему</h4>
        </div>
    </div>

    <div class="ps2-meta">
        <span class="ps2-providers-count">Найдено провайдеров: <span id="paymentStep2Count">0</span></span>
        <span class="ps2-secure"><i class="bi bi-shield-lock-fill"></i> SSL · 3D-Secure</span>
    </div>

    <div class="ps2-list" id="paymentStep2Grid"></div>

    <button type="button" class="ps2-pay" id="paymentStep2PayBtn" disabled
            onclick="confirmStep2Selection()">
        Выберите систему
    </button>

    <div class="ps2-footer">
        <i class="bi bi-info-circle"></i>
        Платёж проходит через сертифицированного провайдера. Данные карты не сохраняются у нас.
    </div>
</div>

<style>
    .ps2 { animation: ps2In 0.2s ease-out; padding: 0.25rem; }
    @@keyframes ps2In { from { opacity: 0; transform: translateX(16px); } to { opacity: 1; transform: translateX(0); } }

    .ps2-top {
        display: flex; align-items: center; gap: 0.85rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 1.1rem;
    }
    .ps2-back {
        width: 38px; height: 38px;
        border-radius: 10px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.85);
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.18s, border-color 0.18s;
    }
    .ps2-back:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.2); }
    .ps2-back i { font-size: 1.1rem; }
    .ps2-top-text { min-width: 0; }
    .ps2-eyebrow { color: rgba(255,255,255,0.5); font-size: 0.8rem; }
    .ps2-method-name { color: #a5b4fc; font-weight: 600; }
    .ps2-title { color: #fff; font-size: 1.15rem; font-weight: 700; margin: 0.15rem 0 0; }

    .ps2-meta {
        display: flex; justify-content: space-between; align-items: center;
        font-size: 0.78rem; color: rgba(255,255,255,0.5);
        margin-bottom: 0.75rem;
    }
    .ps2-secure { display: inline-flex; align-items: center; gap: 0.3rem; }
    .ps2-secure i { color: #22c55e; }

    .ps2-list { display: flex; flex-direction: column; gap: 0.55rem; max-height: 360px; overflow-y: auto; padding-right: 4px; }
    .ps2-list::-webkit-scrollbar { width: 6px; }
    .ps2-list::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); border-radius: 3px; }
    .ps2-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }

    .ps2-tile {
        display: flex; align-items: center; gap: 0.85rem;
        padding: 0.85rem 1rem;
        background: rgba(255,255,255,0.03);
        border: 1.5px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, transform 0.1s;
    }
    .ps2-tile:hover {
        background: rgba(102,126,234,0.07);
        border-color: rgba(102,126,234,0.4);
    }
    .ps2-tile.selected {
        border-color: #667eea;
        background: rgba(102,126,234,0.12);
        box-shadow: 0 0 0 3px rgba(102,126,234,0.12);
    }
    .ps2-tile-icon {
        width: 42px; height: 42px;
        border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 1.05rem;
        flex-shrink: 0;
    }
    .ps2-tile-text { flex: 1; min-width: 0; }
    .ps2-tile-name { color: #fff; font-weight: 600; font-size: 0.95rem; }
    .ps2-tile-meta { color: rgba(255,255,255,0.5); font-size: 0.78rem; margin-top: 0.15rem; display: flex; align-items: center; gap: 0.45rem; }
    .ps2-tile-free { color: #22c55e; font-weight: 500; display: inline-flex; align-items: center; gap: 0.25rem; }
    .ps2-tile-free i { font-size: 0.7rem; }
    .ps2-tile-radio {
        width: 20px; height: 20px;
        border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.25);
        flex-shrink: 0;
        transition: border-color 0.15s, background 0.15s;
    }
    .ps2-tile.selected .ps2-tile-radio {
        border-color: #667eea;
        background: radial-gradient(circle, #667eea 38%, transparent 42%);
    }

    .ps2-pay {
        width: 100%;
        margin-top: 1.1rem;
        padding: 0.9rem 1rem;
        background: var(--primary-gradient, linear-gradient(135deg, #667eea, #764ba2));
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: box-shadow 0.2s, transform 0.1s;
    }
    .ps2-pay:hover:not(:disabled) {
        box-shadow: 0 8px 24px rgba(102,126,234,0.35);
        transform: translateY(-1px);
    }
    .ps2-pay:disabled {
        background: rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.4);
        cursor: not-allowed;
    }

    .ps2-footer {
        display: flex; align-items: center; gap: 0.4rem;
        margin-top: 0.9rem;
        color: rgba(255,255,255,0.4);
        font-size: 0.75rem;
    }
    .ps2-footer i { color: #4facfe; }

    .ps2-empty {
        display: flex; flex-direction: column; align-items: center; text-align: center;
        gap: 0.5rem;
        padding: 1.6rem 1rem;
        background: rgba(255,255,255,0.03);
        border: 1.5px dashed rgba(255,255,255,0.12);
        border-radius: 14px;
    }
    .ps2-empty-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(102,126,234,0.18), rgba(118,75,162,0.18));
        color: #a5b4fc;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
    }
    .ps2-empty-title { color: #fff; font-weight: 700; font-size: 1rem; }
    .ps2-empty-desc { color: rgba(255,255,255,0.55); font-size: 0.85rem; line-height: 1.45; }
    .ps2-empty-desc b { color: rgba(255,255,255,0.85); }
    .ps2-empty-back {
        margin-top: 0.4rem;
        padding: 0.55rem 1rem;
        background: rgba(102,126,234,0.12);
        color: #a5b4fc;
        border: 1px solid rgba(102,126,234,0.4);
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex; align-items: center; gap: 0.4rem;
        transition: background 0.15s, border-color 0.15s;
    }
    .ps2-empty-back:hover { background: rgba(102,126,234,0.2); border-color: #667eea; }
</style>

<script>
(function () {
    /**
     * Catalogue of payment-service providers (PSPs) we've integrated per
     * top-level method category. Today only Enot.io is wired up — and it
     * supports every category. When new gateways come online (BlvckPay,
     * PayPecker, YooKassa, Stripe), add them as additional entries to the
     * relevant arrays — UI shows them as separate provider tiles.
     *
     * Each tile, when clicked, sends just the top-level paymentMethod to
     * the backend. The backend's IPaymentProviderFactory.GetProviderForMethod
     * picks the gateway. Specific Enot service codes (card / mir_card /
     * apple_pay / etc.) are NOT exposed to the user — Enot's own checkout
     * page handles intra-method choice.
     */
    // Only methods actually enabled in our Enot merchant cabinet are listed.
    // Verified against /shops/{shopId}/payment-tariffs — re-check after any
    // tariff change.
    const ENOT_BADGE = 'linear-gradient(135deg, #ff7043, #f4511e)';
    const PLINK_BADGE = 'linear-gradient(135deg, #66c0f4, #1b9adf)';
    // У каждого «работающего» метода - оба PSP, пользователь сам выбирает.
    // Ровно как на Cyborg / NordHosting: видишь два тайла, кликаешь нужный.
    const PROVIDERS_BY_METHOD = {
        card: [
            { code: 'enot',        title: 'Enot Pay',    desc: 'Visa, MasterCard, МИР', icon: 'bi-credit-card-2-front', color: ENOT_BADGE },
            { code: 'paymentlink', title: 'PaymentLink', desc: 'Visa, MasterCard',      icon: 'bi-credit-card',         color: PLINK_BADGE },
        ],
        sbp: [
            { code: 'enot',        title: 'Enot Pay',    desc: 'СБП - реквизиты или QR-код', icon: 'bi-lightning-charge', color: ENOT_BADGE },
            { code: 'paymentlink', title: 'PaymentLink', desc: 'СБП через QR-код банка',     icon: 'bi-qr-code-scan',     color: PLINK_BADGE },
        ],
        // QR - только PaymentLink. Enot нативного QR-метода не имеет
        // (он умеет SBP, у которого QR это просто отображение формы) -
        // не примешиваем его сюда, чтобы не показывать «Enot под QR»
        // там где Enot QR не делает.
        qr: [
            { code: 'paymentlink', title: 'PaymentLink', desc: 'Оплата сканированием QR-кода', icon: 'bi-qr-code', color: PLINK_BADGE },
        ],
        // P2P - заготовка под будущие PSP (BlvckPay / PayPecker).
        p2p: [],
    };

    const METHOD_LABELS = {
        card: 'Банковская карта',
        sbp:  'СБП',
        qr:   'QR-код',
        p2p:  'P2P перевод',
    };

    let currentMethod  = null;
    let currentProvider = null;

    window.openPaymentStep2 = function (method) {
        const providers = PROVIDERS_BY_METHOD[method] || [];
        const grid    = document.getElementById('paymentStep2Grid');
        const label   = document.getElementById('paymentStep2MethodLabel');
        const count   = document.getElementById('paymentStep2Count');
        const step1   = document.getElementById('paymentStep1');
        const step2El = document.getElementById('paymentStep2');
        if (!grid || !step1 || !step2El) return false;

        currentMethod   = method;
        currentProvider = null;
        if (label) label.textContent = METHOD_LABELS[method] || method;
        if (count) count.textContent = providers.length;

        const payBtn = document.getElementById('paymentStep2PayBtn');

        if (providers.length === 0) {
            // Empty-state: метод заявлен, но PSP под него ещё не подключён.
            // Плитка остаётся в шаге 1 как заготовка — но здесь честно
            // показываем «скоро».
            grid.innerHTML = `
                <div class="ps2-empty">
                    <div class="ps2-empty-icon"><i class="bi bi-clock-history"></i></div>
                    <div class="ps2-empty-title">Скоро будет доступно</div>
                    <div class="ps2-empty-desc">
                        Подключаем платёжного провайдера для этого метода.<br/>
                        А пока используйте <b>Банковскую карту</b> или <b>СБП</b>.
                    </div>
                    <button type="button" class="ps2-empty-back" onclick="closePaymentStep2()">
                        <i class="bi bi-arrow-left"></i> Выбрать другой метод
                    </button>
                </div>
            `;
            payBtn.disabled = true;
            payBtn.textContent = 'Метод недоступен';
        } else {
            grid.innerHTML = providers.map(p => `
                <div class="ps2-tile" data-method="${method}" data-provider="${p.code}">
                    <div class="ps2-tile-icon" style="background: ${p.color};">
                        <i class="bi ${p.icon}"></i>
                    </div>
                    <div class="ps2-tile-text">
                        <div class="ps2-tile-name">${p.title}</div>
                        <div class="ps2-tile-meta">
                            <span>${p.desc}</span>
                            <span>·</span>
                            <span class="ps2-tile-free"><i class="bi bi-check-circle-fill"></i> Без комиссии</span>
                        </div>
                    </div>
                    <div class="ps2-tile-radio"></div>
                </div>
            `).join('');

            grid.querySelectorAll('.ps2-tile').forEach(tile => {
                tile.addEventListener('click', () => selectTile(tile));
            });

            // Никакого auto-select - даже если провайдер один, пользователь
            // должен явно нажать на тайл. Так шаг 2 всегда выглядит как
            // полноценный экран выбора, а не «промежуточная заглушка».
            payBtn.disabled = true;
            payBtn.textContent = 'Выберите систему';
        }

        // Toggle modal screens — also hide the picker wrapper that exists as a
        // sibling so only one modal-body renders at a time.
        step1.style.display = 'none';
        step2El.style.display = 'block';
        const wrapper = document.getElementById('paymentStep2Wrapper');
        if (wrapper) wrapper.style.display = 'block';
        return true;
    };

    window.closePaymentStep2 = function () {
        const step1   = document.getElementById('paymentStep1');
        const step2El = document.getElementById('paymentStep2');
        const wrapper = document.getElementById('paymentStep2Wrapper');
        if (step1)   step1.style.display = '';
        if (step2El) step2El.style.display = 'none';
        if (wrapper) wrapper.style.display = 'none';
    };

    function selectTile(tile) {
        document.querySelectorAll('.ps2-tile').forEach(t => t.classList.remove('selected'));
        tile.classList.add('selected');
        currentProvider = tile.dataset.provider;

        const payBtn = document.getElementById('paymentStep2PayBtn');
        const total  = window.lastSelectedPrice || 0;
        if (total > 0) {
            payBtn.textContent = `Оплатить ${Number(total).toLocaleString('ru-RU')} ₽`;
        } else {
            payBtn.textContent = 'Перейти к оплате';
        }
        payBtn.disabled = false;
    }

    window.confirmStep2Selection = function () {
        if (!currentMethod || !currentProvider) return;
        const payBtn = document.getElementById('paymentStep2PayBtn');
        payBtn.disabled = true;
        payBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Обработка…';

        // Pass top-level method PLUS the picked provider's code (e.g. "enot",
        // "paymentlink"). Backend uses it to route to the right
        // IPaymentProvider instead of relying on first-match.
        window.lastSelectedProvider = currentProvider;
        if (typeof window.submitPurchaseWithService === 'function') {
            window.submitPurchaseWithService(currentMethod, currentProvider, null);
        } else {
            console.error('submitPurchaseWithService is not defined on this page');
            alert('Ошибка инициализации');
            payBtn.disabled = false;
            payBtn.textContent = 'Перейти к оплате';
        }
    };
})();
</script>
