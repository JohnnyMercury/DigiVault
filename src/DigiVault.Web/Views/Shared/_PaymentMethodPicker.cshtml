@*
    Step-2 payment system picker for the purchase modal.

    Render this partial inside the modal body (sibling of #paymentStep1).
    JS contract:
      - call `window.openPaymentStep2(method)` to switch from step 1 to this view
      - back button calls `window.closePaymentStep2()`
      - clicking a tile selects it; clicking the bottom "Оплатить" calls
        `window.submitPurchaseWithService(method, serviceCode, tile)` which
        the host page (Game/GiftCard/VpnProvider/Telegram) defines.
*@

<div id="paymentStep2" class="ps2" style="display:none;">
    <div class="ps2-top">
        <button type="button" class="ps2-back" onclick="closePaymentStep2()">
            <i class="bi bi-arrow-left"></i>
        </button>
        <div class="ps2-top-text">
            <div class="ps2-eyebrow">
                Способ оплаты: <span class="ps2-method-name" id="paymentStep2MethodLabel">—</span>
            </div>
            <h4 class="ps2-title">Выберите платёжную систему</h4>
        </div>
    </div>

    <div class="ps2-meta">
        <span class="ps2-providers-count">Найдено провайдеров: <span id="paymentStep2Count">0</span></span>
        <span class="ps2-secure"><i class="bi bi-shield-lock-fill"></i> SSL · 3D-Secure</span>
    </div>

    <div class="ps2-list" id="paymentStep2Grid"></div>

    <button type="button" class="ps2-pay" id="paymentStep2PayBtn" disabled
            onclick="confirmStep2Selection()">
        Выберите систему
    </button>

    <div class="ps2-footer">
        <i class="bi bi-info-circle"></i>
        Платёж проходит через сертифицированного провайдера. Данные карты не сохраняются у нас.
    </div>
</div>

<style>
    .ps2 { animation: ps2In 0.2s ease-out; padding: 0.25rem; }
    @@keyframes ps2In { from { opacity: 0; transform: translateX(16px); } to { opacity: 1; transform: translateX(0); } }

    .ps2-top {
        display: flex; align-items: center; gap: 0.85rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        margin-bottom: 1.1rem;
    }
    .ps2-back {
        width: 38px; height: 38px;
        border-radius: 10px;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.1);
        color: rgba(255,255,255,0.85);
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.18s, border-color 0.18s;
    }
    .ps2-back:hover { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.2); }
    .ps2-back i { font-size: 1.1rem; }
    .ps2-top-text { min-width: 0; }
    .ps2-eyebrow { color: rgba(255,255,255,0.5); font-size: 0.8rem; }
    .ps2-method-name { color: #a5b4fc; font-weight: 600; }
    .ps2-title { color: #fff; font-size: 1.15rem; font-weight: 700; margin: 0.15rem 0 0; }

    .ps2-meta {
        display: flex; justify-content: space-between; align-items: center;
        font-size: 0.78rem; color: rgba(255,255,255,0.5);
        margin-bottom: 0.75rem;
    }
    .ps2-secure { display: inline-flex; align-items: center; gap: 0.3rem; }
    .ps2-secure i { color: #22c55e; }

    .ps2-list { display: flex; flex-direction: column; gap: 0.55rem; max-height: 360px; overflow-y: auto; padding-right: 4px; }
    .ps2-list::-webkit-scrollbar { width: 6px; }
    .ps2-list::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); border-radius: 3px; }
    .ps2-list::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 3px; }

    .ps2-tile {
        display: flex; align-items: center; gap: 0.85rem;
        padding: 0.85rem 1rem;
        background: rgba(255,255,255,0.03);
        border: 1.5px solid rgba(255,255,255,0.08);
        border-radius: 12px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, transform 0.1s;
    }
    .ps2-tile:hover {
        background: rgba(102,126,234,0.07);
        border-color: rgba(102,126,234,0.4);
    }
    .ps2-tile.selected {
        border-color: #667eea;
        background: rgba(102,126,234,0.12);
        box-shadow: 0 0 0 3px rgba(102,126,234,0.12);
    }
    .ps2-tile-icon {
        width: 42px; height: 42px;
        border-radius: 11px;
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-size: 1.05rem;
        flex-shrink: 0;
    }
    .ps2-tile-text { flex: 1; min-width: 0; }
    .ps2-tile-name { color: #fff; font-weight: 600; font-size: 0.95rem; }
    .ps2-tile-meta { color: rgba(255,255,255,0.5); font-size: 0.78rem; margin-top: 0.15rem; display: flex; align-items: center; gap: 0.45rem; }
    .ps2-tile-free { color: #22c55e; font-weight: 500; display: inline-flex; align-items: center; gap: 0.25rem; }
    .ps2-tile-free i { font-size: 0.7rem; }
    .ps2-tile-radio {
        width: 20px; height: 20px;
        border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.25);
        flex-shrink: 0;
        transition: border-color 0.15s, background 0.15s;
    }
    .ps2-tile.selected .ps2-tile-radio {
        border-color: #667eea;
        background: radial-gradient(circle, #667eea 38%, transparent 42%);
    }

    .ps2-pay {
        width: 100%;
        margin-top: 1.1rem;
        padding: 0.9rem 1rem;
        background: var(--primary-gradient, linear-gradient(135deg, #667eea, #764ba2));
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: box-shadow 0.2s, transform 0.1s;
    }
    .ps2-pay:hover:not(:disabled) {
        box-shadow: 0 8px 24px rgba(102,126,234,0.35);
        transform: translateY(-1px);
    }
    .ps2-pay:disabled {
        background: rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.4);
        cursor: not-allowed;
    }

    .ps2-footer {
        display: flex; align-items: center; gap: 0.4rem;
        margin-top: 0.9rem;
        color: rgba(255,255,255,0.4);
        font-size: 0.75rem;
    }
    .ps2-footer i { color: #4facfe; }
</style>

<script>
(function () {
    /**
     * Catalogue: which Enot services are exposed for each top-level method.
     * Edit when Enot's enabled tariffs change in the merchant cabinet.
     * Each entry's `code` is sent as enotService → Enot's include_service[0].
     */
    const ENOT_SERVICES = {
        card: [
            { code: 'card',       title: 'Visa / MasterCard',  desc: 'Российские и зарубежные банки', icon: 'bi-credit-card-2-front', color: 'linear-gradient(135deg, #4facfe, #00f2fe)' },
            { code: 'mir_card',   title: 'Карта МИР',          desc: 'Российские карты',              icon: 'bi-credit-card',         color: 'linear-gradient(135deg, #22c55e, #16a34a)' },
            { code: 'apple_pay',  title: 'Apple Pay',          desc: 'iPhone / Mac',                  icon: 'bi-apple',               color: 'linear-gradient(135deg, #1a1a1a, #4a4a4a)' },
            { code: 'google_pay', title: 'Google Pay',         desc: 'Android / Google Wallet',       icon: 'bi-google',              color: 'linear-gradient(135deg, #4285f4, #34a853)' },
            { code: 'p2p_card',   title: 'P2P на карту',       desc: 'Прямой перевод с карты на карту', icon: 'bi-people',            color: 'linear-gradient(135deg, #ec4899, #db2777)' },
        ],
        sbp: [
            { code: 'sbp',     title: 'СБП',     desc: 'Система быстрых платежей',  icon: 'bi-lightning-charge', color: 'linear-gradient(135deg, #8b5cf6, #6d28d9)' },
            { code: 'p2p_sbp', title: 'P2P СБП', desc: 'P2P через систему быстрых платежей', icon: 'bi-people', color: 'linear-gradient(135deg, #ec4899, #db2777)' },
        ],
        qr: [
            { code: 'sbp', title: 'СБП QR-код', desc: 'Сканируйте QR в банковском приложении', icon: 'bi-qr-code', color: 'linear-gradient(135deg, #f59e0b, #d97706)' },
        ],
        p2p: [
            { code: 'p2p_card', title: 'P2P Карта', desc: 'Перевод на карту получателя',  icon: 'bi-credit-card', color: 'linear-gradient(135deg, #ec4899, #db2777)' },
            { code: 'p2p_sbp',  title: 'P2P СБП',   desc: 'Перевод через СБП',            icon: 'bi-lightning-charge', color: 'linear-gradient(135deg, #8b5cf6, #6d28d9)' },
        ],
        crypto: [
            { code: 'bitcoin',      title: 'Bitcoin',       desc: 'BTC',                icon: 'bi-currency-bitcoin', color: 'linear-gradient(135deg, #f7931a, #e76b00)' },
            { code: 'usdt_trc20',   title: 'USDT TRC20',    desc: 'Tether в сети TRON', icon: 'bi-circle-fill',      color: 'linear-gradient(135deg, #26a17b, #1a7d5c)' },
            { code: 'usdt_erc20',   title: 'USDT ERC20',    desc: 'Tether в сети ETH',  icon: 'bi-circle-fill',      color: 'linear-gradient(135deg, #26a17b, #1a7d5c)' },
            { code: 'ethereum',     title: 'Ethereum',      desc: 'ETH',                icon: 'bi-diamond-fill',     color: 'linear-gradient(135deg, #627eea, #4357c7)' },
            { code: 'litecoin',     title: 'Litecoin',      desc: 'LTC',                icon: 'bi-circle-fill',      color: 'linear-gradient(135deg, #345d9d, #1d3a6a)' },
            { code: 'ton',          title: 'TON',           desc: 'The Open Network',   icon: 'bi-send-fill',        color: 'linear-gradient(135deg, #0098ea, #0077b8)' },
            { code: 'trx',          title: 'TRON',          desc: 'TRX',                icon: 'bi-triangle-fill',    color: 'linear-gradient(135deg, #ef0027, #c20020)' },
            { code: 'bitcoin_cash', title: 'Bitcoin Cash',  desc: 'BCH',                icon: 'bi-currency-bitcoin', color: 'linear-gradient(135deg, #0ac18e, #069970)' },
            { code: 'dash',         title: 'DASH',          desc: 'DASH',               icon: 'bi-circle-fill',      color: 'linear-gradient(135deg, #008ce7, #006fb8)' },
        ],
        wallet: [
            { code: 'qiwi',          title: 'QIWI',          desc: 'QIWI Кошелёк',     icon: 'bi-wallet2',     color: 'linear-gradient(135deg, #ff8c00, #d97706)' },
            { code: 'yoomoney',      title: 'ЮMoney',        desc: 'Яндекс.Деньги',    icon: 'bi-wallet-fill', color: 'linear-gradient(135deg, #8b3a8b, #6b1f6b)' },
            { code: 'webmoney',      title: 'WebMoney',      desc: 'WebMoney Transfer', icon: 'bi-wallet',     color: 'linear-gradient(135deg, #0099d8, #006ba6)' },
            { code: 'advcash',       title: 'Advcash',       desc: 'Advanced Cash',    icon: 'bi-wallet-fill', color: 'linear-gradient(135deg, #1f6feb, #0c4ac3)' },
            { code: 'perfect_money', title: 'Perfect Money', desc: 'Perfect Money',    icon: 'bi-cash-coin',   color: 'linear-gradient(135deg, #d4af37, #a37e1f)' },
        ],
    };

    const METHOD_LABELS = {
        card:   'Банковская карта',
        sbp:    'СБП',
        qr:     'QR-код',
        p2p:    'P2P перевод',
        crypto: 'Криптовалюта',
        wallet: 'Электронный кошелёк',
    };

    let currentMethod  = null;
    let currentService = null;

    window.openPaymentStep2 = function (method) {
        const services = ENOT_SERVICES[method];
        if (!services || services.length === 0) {
            console.warn('[ps2] no services for method:', method);
            return false;
        }
        const grid    = document.getElementById('paymentStep2Grid');
        const label   = document.getElementById('paymentStep2MethodLabel');
        const count   = document.getElementById('paymentStep2Count');
        const step1   = document.getElementById('paymentStep1');
        const step2El = document.getElementById('paymentStep2');
        if (!grid || !step1 || !step2El) return false;

        currentMethod  = method;
        currentService = null;
        if (label) label.textContent = METHOD_LABELS[method] || method;
        if (count) count.textContent = services.length;

        grid.innerHTML = services.map(s => `
            <div class="ps2-tile" data-method="${method}" data-service="${s.code}">
                <div class="ps2-tile-icon" style="background: ${s.color};">
                    <i class="bi ${s.icon}"></i>
                </div>
                <div class="ps2-tile-text">
                    <div class="ps2-tile-name">${s.title}</div>
                    <div class="ps2-tile-meta">
                        <span>${s.desc}</span>
                        <span>·</span>
                        <span class="ps2-tile-free"><i class="bi bi-check-circle-fill"></i> Без комиссии</span>
                    </div>
                </div>
                <div class="ps2-tile-radio"></div>
            </div>
        `).join('');

        grid.querySelectorAll('.ps2-tile').forEach(tile => {
            tile.addEventListener('click', () => selectTile(tile));
        });

        // Reset Pay button
        const payBtn = document.getElementById('paymentStep2PayBtn');
        payBtn.disabled = true;
        payBtn.textContent = 'Выберите систему';

        // Toggle modal screens — also hide the picker wrapper that exists as a
        // sibling so only one modal-body renders at a time.
        step1.style.display = 'none';
        step2El.style.display = 'block';
        const wrapper = document.getElementById('paymentStep2Wrapper');
        if (wrapper) wrapper.style.display = 'block';
        return true;
    };

    window.closePaymentStep2 = function () {
        const step1   = document.getElementById('paymentStep1');
        const step2El = document.getElementById('paymentStep2');
        const wrapper = document.getElementById('paymentStep2Wrapper');
        if (step1)   step1.style.display = '';
        if (step2El) step2El.style.display = 'none';
        if (wrapper) wrapper.style.display = 'none';
    };

    function selectTile(tile) {
        document.querySelectorAll('.ps2-tile').forEach(t => t.classList.remove('selected'));
        tile.classList.add('selected');
        currentService = tile.dataset.service;

        // Update Pay button label with order total if the page set window.lastSelectedPrice.
        const payBtn = document.getElementById('paymentStep2PayBtn');
        const total  = window.lastSelectedPrice || 0;
        if (total > 0) {
            payBtn.textContent = `Оплатить ${Number(total).toLocaleString('ru-RU')} ₽`;
        } else {
            payBtn.textContent = 'Перейти к оплате';
        }
        payBtn.disabled = false;
    }

    window.confirmStep2Selection = function () {
        if (!currentMethod || !currentService) return;
        const payBtn = document.getElementById('paymentStep2PayBtn');
        payBtn.disabled = true;
        payBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Обработка…';

        if (typeof window.submitPurchaseWithService === 'function') {
            window.submitPurchaseWithService(currentMethod, currentService, null);
        } else {
            console.error('submitPurchaseWithService is not defined on this page');
            alert('Ошибка инициализации');
            payBtn.disabled = false;
            payBtn.textContent = 'Перейти к оплате';
        }
    };
})();
</script>
